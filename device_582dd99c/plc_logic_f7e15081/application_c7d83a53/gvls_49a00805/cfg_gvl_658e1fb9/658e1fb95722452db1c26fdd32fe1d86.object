{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)658e1fb9-5722-452d-b1c2-6fdd32fe1d86","ParentGuid":"(Guid)c7d83a53-1e97-460d-93a6-673fb1d7fa43","Name":"(string)Cfg_GVL","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)49a00805-f056-47bc-a9ea-6d1a672d4e7d"}]}}}}]},"TypeGuid":"(Guid)ffbfa93a-b94d-45fc-a329-229860183b1d","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"ffbfa93a","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string){attribute 'qualified_only'}\n(*\n|\tPlant Config GVL\n|\tContains all config variables for site\n|\tEntire GVL uses retained memory\n*)\nVAR_GLOBAL\n\t//Plant-Level Cfg\n\tEMSCfg_eng\t\t\t: dt_EMSCfg; \n\tEMSCfg_pu\t\t\t: dt_EMSCfg;\t\n\t\n\t//Lineup-Level Cfg\n\tLUAlarmCfg_eng\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUAlarmCfg;\t\t\t\t//Lineup Alarm Configuration Struct (engineering units for configuration purposes/SCADA)\n\tLUAlarmCfg_pu\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUAlarmCfg;\t\t\t\t//Lineup Alarm Configuration Struct (percentage units for core logic)\n\tLUCfg_pu\t \t\t: ARRAY[0..SiteConstants.NumUnits] OF dt_LUCfg;\t\t\t\t\t\t//Line Up configuration structure (percentage units for core logic)\n\tLUCfg_eng\t \t\t: ARRAY[0..SiteConstants.NumUnits] OF dt_LUCfg;\t\t\t\t\t\t//Line Up configuration structure (engineering units for configuration purposes/SCADA_\n\t\n\t//EMSPlantCfg_pu \t\t: TBE_EMS_DTs.dt_EMS_Cfg;\t\t\t\t\t\t\t\t\t\t//EMS Plant configuration structure\n\t//EMSPlantCfg_Eng \t: TBE_EMS_DTs.dt_EMS_Cfg;\t\t\t\t\t\t\t\t\t\t\t//EMS Plant configuration structure (in engineering units)\n\t\n\tCfgComplete\t\t\t: BOOL; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Boolean variable to determine if initial/default configuration variables have been set\n\tEnableSELHMICtrl\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Boolean variable to enable/disable SEL HMI \n\tTaskTime\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//[ms], Task cycle time\nEND_VAR","LineInfoPersistence":"(string)658e1fb9-5722-452d-b1c2-6fdd32fe1d86_Decl_LineIds"}}}},"NetVarProperties":null,"ParameterList":"(bool)False","AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","ffbfa93a":"{ffbfa93a-b94d-45fc-a329-229860183b1d}","string":"System.String"}}},"FormatVersion":"1.0"}