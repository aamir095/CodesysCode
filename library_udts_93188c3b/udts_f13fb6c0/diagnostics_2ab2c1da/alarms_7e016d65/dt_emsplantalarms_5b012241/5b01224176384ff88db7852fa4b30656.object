{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)5b012241-7638-4ff8-8db7-852fa4b30656","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_EMSPlantAlarms","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)7e016d65-50c4-4698-97c7-00b8ac82b4d1"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tEMS Plant Alarms Structure \n*)\nTYPE dt_EMSPlantAlarms :\nSTRUCT\n\tPPCCommFault\t\t: BOOL;\t\t//[True = PPC is Offline, False = PPC is online and communicating with EMS]\n\tSCADACommFault\t\t: BOOL;\t\t//[True = SCADA is offline/not communicating, False = SCADA is online and communicating with EMS]\n\tMeterCommFault\t\t: BOOL; \t//[True = Meter is offline/not communicating, False = Meter is online and communicating with EMS]\n\tAllLUsOffline\t\t: BOOL;\t\t//[True = All Lineups Offline/notn communicationg, False = At least 1 Lineup is online/communicating]\n\tHalfLUsOffline\t\t: BOOL;\t\t//[True = At least 50% Lineups Offline/notn communicationg, False = more than 50% Lineup is online/communicating]\n\tMostLUsOffline\t\t: BOOL;\t\t//[True = At least 80% Lineups Offline/notn communicationg, False = more than 80% Lineup is online/communicating]\n\t\n\t//Plant Alarm Level\n\tAlarmLevel\t\t: enum_AlarmLevel;\t\n\t\n\t//Plant-Level Feedback Alarms\n\tPFbk\t\t\t\t: dt_Alarm;\n\tQFbk\t\t\t\t: dt_Alarm;\n\tSOC\t\t\t    \t: dt_Alarm;\n\t\n\t//Hardware Fault\n\tEMSHardwareFault\t: BOOL;\n\tEMSSupplyVoltFault\t: BOOL;\n\tEMSCPUUsageHigh\t\t: BOOL;\n\t\n\t//Plant Alarm Level\n\tPlantAlarmLevel\t\t: enum_AlarmLevel;\t\t//Lineup alarm level\n\t\n\t//Operating Mode Level\n\tPOpenLoop\t\t\t: BOOL;\t\t\t//Active Power in Open Loop Mode\n\tQOpenLoop\t\t\t: BOOL;\t\t\t//Reactive power in open loop mode\nEND_STRUCT\nEND_TYPE\n","LineInfoPersistence":"(string)5b012241-7638-4ff8-8db7-852fa4b30656_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)36"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}