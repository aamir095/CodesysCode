{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)8c811cfe-e84d-466b-8571-95663e45576d","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_LUAlarms","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)7e016d65-50c4-4698-97c7-00b8ac82b4d1"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tLineup Alarm Structure\n*)\nTYPE dt_LUAlarms :\nSTRUCT\n\t//OEM Alarms (from Lineup)\n\tHVACAlarm\t\t: BOOL;\t\t\t\t\t//[True = HVAC Alarm reported from Lineup, False = HVAC Alarm not reported]\n\tFireSuppAlarm\t: BOOL;\t\t\t\t\t//[True = Fire suppression alarm reported from lineup, False = fire suppression alarm not reported]\n\tContDoorOpen\t: BOOL;\t\t\t\t\t//[True = Container door open, False = Container door not open]\n\tAuxSysFault\t\t: BOOL;\t\t\t\t\t//[True = Auxiliary system fault active, False = Auxiliary system fault not active]\n\t\n\t//Boolean Alarms\n\tOffline\t\t\t: BOOL;\t\t\t\t\t//[True = Lineup communication is offline, False = Lineup communication is okay]\n\t\n\t//Limit Alarms\n\tContTemp\t\t: dt_Alarm;\t\t\t\t//Container temperature alarm structure\n\tContHumid\t\t: dt_Alarm;\t\t\t\t//Container humidity alarm structure\n\tSOC\t\t\t\t: dt_Alarm;\t\t\t\t//Sate of Charge alarm structure\n\tSOH\t\t\t\t: dt_Alarm;\t\t\t\t//Sate of Charge alarm structure\n\tDCVoltage\t\t: dt_Alarm;\t\t\t\t//DC Voltage alarm structure\n\tACVoltage\t\t: dt_Alarm;\t\t\t\t//AC Voltage alarm structure\n\tDCCurrent\t\t: dt_Alarm;\t\t\t\t//DC Voltage alarm structure\n\tACCurrent\t\t: dt_Alarm;\t\t\t\t//DC Voltage alarm structure\n\t\n\t//LU Alarm Level\n\tAlarmLevel\t\t: enum_AlarmLevel;\t\t//Lineup alarm level\nEND_STRUCT\nEND_TYPE\n","LineInfoPersistence":"(string)8c811cfe-e84d-466b-8571-95663e45576d_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)37"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}