{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)a45c3edf-b1d7-4ca6-b53a-bb4b23068b7d","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_LUFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)16b88c1c-2997-4dc1-9c84-b22d9bf8598c"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tLineup Feedback Structure\n*)\nTYPE dt_LUFbk :\nSTRUCT\n\tPspReceived\t\t\t: REAL;\t\t\t\t\t//Received Active Power Setpoints \n\tQspReceived\t\t\t: REAL;\t\t\t\t\t//Received Reactive Power Setpoints\n\tPRampUpRtReceived\t: REAL;\t\t\t\t\t//Received Active Power Ramp Up Rate\n\tPRampDnRtReceived\t: REAL; \t\t\t\t//Received Active Power Down Rate\n\tQRampUpRtReceived\t: REAL; \t\t\t\t//Received Reactive Power Ramp Up Rate\n\tQRampDnRtReceived\t: REAL;  \t\t\t\t//Received Reactive Power Ramp Down Rate\n\tState \t\t\t\t: TBE_EMS_DTs.enum_LineUp_State; \t//LineUp Diagnostics Status\n\tOpMode\t\t\t\t: TBE_EMS_DTs.enum_LineUp_OpMode;\t//LineUp Operational Mode (Power Limit/ SoC Limit)\n\tOpSts\t\t\t\t: TBE_EMS_DTs.enum_LineUp_Op;\t\t//Operational Status of the LineUp\n\tAuto\t\t\t\t: BOOL;\n\tPAuto\t\t\t\t: BOOL;\t\t\t\t\t//Auto/ Manual Control Status for Active Power Control\n\tQAuto\t\t\t\t: BOOL;\t\t\t\t\t//Auto/ Manual Control Status for Reactive Power Control\n\tPwrChaCap\t\t\t: REAL;\t\t\t\t\t//Active Power Charging Capacity\n\tPwrDisChaCap\t\t: REAL;\t\t\t\t\t//Active Power Disharging Capacity\n\tRePwrAbsCap\t\t\t: REAL;\t\t\t\t\t//Reactive Power Absorb Capacity\n\tRePwrInjCap\t\t\t: REAL;\t\t\t\t\t//Reactive Power Inject Capacity\n\tContDoorOpen\t\t: BOOL;\t\t\t\t\t//Container Door Condition\n\tContTemp\t\t\t: REAL;\t\t\t\t\t//Measured Container Temperature \n\tContHumid\t\t\t: REAL;\t\t\t\t\t//Measured Container Humidity \n\tInvSts\t\t\t\t: TBE_EMS_DTs.enum_Inv_State;\t\t//Inverter State \n\tInvACPwr\t\t\t: REAL;\t\t\t\t\t//Inverter Output Acitve Power \n\tInvRePwr\t\t\t: REAL;\t\t\t\t\t//Inverter Output Reactive Power \n\tInvApPwr\t\t\t: REAL;\t\t\t\t\t//Inverter Output Apparent Power \n\tInvDCV\t\t\t\t: REAL;\t\t\t\t\t//Inverter DC Input Voltage \n\tInvACV\t\t\t\t: REAL;\t\t\t\t\t//Inverter AC Voltage (L-L Average)\n\tInvDCA\t\t\t\t: REAL;\t\t\t\t\t//Inverter DC Input Current\n\tInvACA\t\t\t\t: REAL;\t\t\t\t\t//Inverter AC Current (average)\n\tInvDCPwr\t\t\t: REAL;\t\t\t\t\t//Inverter DC Input Power\n\tAvgSoC\t\t\t\t: REAL;\t\t\t\t\t//Average State of Charge of the LineUp\n\tAvgSoH\t\t\t\t: REAL;\t\t\t\t\t//Average State of Health of the LineUp\n\tAlmFire\t\t\t\t: BOOL;\t\t\t\t\t//Fire Alarm for the Container\n\tStsFireSupp\t\t\t: TBE_EMS_DTs.enum_FireSupp_Sts;\t//Fire Suppression status\n\tAlmHVAC\t\t\t\t: BOOL;\t\t\t\t\t//HVAC Alarm for the Container\n\tStsHVAC\t\t\t\t: TBE_EMS_DTs.enum_HVAC_Sts;\t\t//HVAC status\n\tAlmComm\t\t\t\t: BOOL;\nEND_STRUCT\nEND_TYPE\n","LineInfoPersistence":"(string)a45c3edf-b1d7-4ca6-b53a-bb4b23068b7d_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)43"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}