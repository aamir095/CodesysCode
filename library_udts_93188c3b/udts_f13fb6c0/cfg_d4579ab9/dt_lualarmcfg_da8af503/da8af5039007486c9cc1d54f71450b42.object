{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)da8af503-9007-486c-9cc1-d54f71450b42","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_LUAlarmCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d4579ab9-7cca-449a-8b70-17636b1c5023"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tAlarm Configuration Struct\n*)\nTYPE dt_LUAlarmCfg :\nSTRUCT\n\t//Timer configuration - Feedback and SP/Fbk Deviation alarms will be set once the alarm conditions are met for longer than the AlmThreshTime duration\n\tThreshTime\t\t: TIME;\t\t\t//Feedback and SP/Fbk Deviation alarms will be set once the alarm conditions are met for longer than the AlmThreshTime duration\n\t\n\t//LU Feedback Alarms - Lo/LoLo/Hi/HiHi limits will be configured\n\tPFbk\t\t\t: TBE_DTs.dt_Lim; \t\t//Active power feedback limit values\n\tQFbk\t\t\t: TBE_DTs.dt_Lim; \t\t//Reactive power feedback limit values\n\tSOCFbk\t\t\t: TBE_DTs.dt_Lim;\t\t//State of charge alarm limit values\n\tSOHFbk\t\t\t: TBE_DTs.dt_Lim; \t\t//State of health alarm limit values\n\tDCVoltageFbk\t: TBE_DTs.dt_Lim;\t\t//DC Voltage alarm limit values\n\tACVoltageFbk\t: TBE_DTs.dt_Lim;\t\t//AC Voltage alarm limit values\n\tDCCurrentFbk\t: TBE_DTs.dt_Lim;\t\t//DC Current alarm limit values\n\tACCurrentFbk\t: TBE_DTs.dt_Lim;\t\t//AC Current alarm limit values\n\tContTempFbk\t\t: TBE_DTs.dt_Lim;\t\t//Container temperature alarm limit values\n\tContHumidFbk\t: TBE_DTs.dt_Lim;\t\t//Container humidity alarm limit values\nEND_STRUCT\nEND_TYPE\n","LineInfoPersistence":"(string)da8af503-9007-486c-9cc1-d54f71450b42_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)92"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}