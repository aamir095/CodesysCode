{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)f27bb59c-4637-46d7-bde9-ae75fb3fc8f6","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_QSpCtrlOutputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)65ee9471-e7f4-4696-8c04-cb37963c1220"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tReactive power setpoint control outputs (inputs to reactive power closed loop control block\n*)\nTYPE dt_QSpCtrlOutputs :\nSTRUCT\n\tQSp_PreRamp\t\t\t: REAL;\t\t//Reactive power setpoint prior to application of ramp rate\n\tQSp_PostRamp\t\t: REAL;\t\t//Reactive power setpoint after application of ramp rate and prior to limiting logic\n\tQSp_PostLim\t\t\t: REAL;\t\t//Reactive power setpoint after limiting logic\n\tQClosedLoopCtrlEn\t: BOOL;\t\t//[True = Reactive power closed loop control enabled, False = reactive power closed loop control disabled]\n\tPFCtlMode\t\t\t: BOOL;\t\t//Power Factor Control Logic\n\tLimSP\t\t\t\t: BOOL;\t\t//Power Setpoint Limit by controller (TRUE = Enable, FALSE = Disable)\n\tLimPF\t\t\t\t: BOOL;\t\t//Power Factor Limit by controller (TRUE = Enable, FALSE = Disable)\nEND_STRUCT\nEND_TYPE\n","LineInfoPersistence":"(string)f27bb59c-4637-46d7-bde9-ae75fb3fc8f6_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)16"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}