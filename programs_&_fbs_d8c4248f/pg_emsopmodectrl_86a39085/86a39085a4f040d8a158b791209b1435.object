{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)86a39085-a4f0-40d8-a158-b791209b1435","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_EMSOpModeCtrl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine pre-reqs for operating in SCADA, PPC and Stop Modes\nEMSOpSts.PPCOpModePerm := NOT EMSPlantAlarms.PPCCommFault AND NOT EMSPlantAlarms.AllLUsOffline;\nEMSOPSts.SCADAOpModePerm := NOT EMSPlantAlarms.SCADACommFault AND NOT EMSPlantAlarms.AllLUsOffline;\n\n//Determine Active Power Operating State of EMS\nIF HMIInputs.ActivePwrHMIInputs.OpModeCmd = enum_EMSOpModeCmd.PPC AND EMSOpSts.PPCOpModePerm THEN\n\t//Operating state is PPC Control - EMS will use P/Q setpoints from PPC\n\tEMSOpSts.POpState := enum_EMSOpState.PPC;\nELSIF HMIInputs.ActivePwrHMIInputs.OpModeCmd = enum_EMSOpModeCmd.SCADA AND EMSOpSts.SCADAOpModePerm THEN\n\t//Operating state if SCADA Control - EMS will use P/Q setpoints from SCADA\n\tEMSOpSts.POpState := enum_EMSOpState.SCADA;\nELSIF HMIInputs.ActivePwrHMIInputs.OpModeCmd = enum_EMSOpModeCmd.Stop AND EMSOpSts.SCADAOpModePerm THEN\n\t//Operating state is STOP (received from SCADA)\n\tEMSOpSts.POpState := enum_EMSOpState.Stop;\nELSE\n\t//EMS is faulted - set state to FAULT\n\tEMSOpSts.POpState := enum_EMSOpState.Fault;\nEND_IF\n\n//Determine Reactive Power Operating State of EMS\nIF HMIInputs.ReactivePwrHMIInputs.OpModeCmd = enum_EMSOpModeCmd.PPC AND EMSOpSts.PPCOpModePerm THEN\n\t//Operating state is PPC Control - EMS will use P/Q setpoints from PPC\n\tEMSOpSts.QOpState := enum_EMSOpState.PPC;\nELSIF HMIInputs.ReactivePwrHMIInputs.OpModeCmd = enum_EMSOpModeCmd.SCADA AND EMSOpSts.SCADAOpModePerm THEN\n\t//Operating state if SCADA Control - EMS will use P/Q setpoints from SCADA\n\tEMSOpSts.QOpState := enum_EMSOpState.SCADA;\nELSIF HMIInputs.ReactivePwrHMIInputs.OpModeCmd = enum_EMSOpModeCmd.Stop AND EMSOpSts.SCADAOpModePerm THEN\n\t//Operating state is STOP (received from SCADA)\n\tEMSOpSts.QOpState := enum_EMSOpState.Stop;\nELSE\n\t//EMS is faulted - set state to FAULT\n\tEMSOpSts.QOpState := enum_EMSOpState.Fault;\nEND_IF\n\n\n// P Closed Loop Control Permission\nEMSOpSts.PClosedLoopCtrlPerm :=  Meter_GVL.CommOK AND EMSVFbk.LUAvailPct > 50.0 AND (EMSOpSts.POpState = enum_EMSOpState.PPC OR EMSOpSts.POpState = enum_EMSOpState.SCADA);\n\n// Q Closed Loop Control Permission\nEMSOPSts.QClosedLoopCtrlPerm := Meter_GVL.CommOK  AND EMSVFbk.LUAvailPct > 50.0 AND (EMSOpSts.QOpState = enum_EMSOpState.PPC OR EMSOpSts.QOpState = enum_EMSOpState.SCADA);\n\n\n\n\n(*\n//Determine permissives for active and reactive power closed loop control\n//No Meter Fault - Close Loop Control Allowed\nIF NOT MeterFbk.Sts_Flt AND EMSVFbk.LUAvailPct > 50.0 THEN\n\tEMSOpSts.PClosedLoopCtrlPerm := TRUE;\n\tEMSOPSts.QClosedLoopCtrlPerm := TRUE;\nELSIF MeterFbk.Sts_Flt OR EMSVFbk.LUAvailPct < 50.0 THEN\n\tEMSOpSts.PClosedLoopCtrlPerm := FALSE;\n\tEMSOPSts.QClosedLoopCtrlPerm := FALSE;\nELSE\n\t//Meter Fault Present - Disable Close Loop Control\n\tEMSOpSts.PClosedLoopCtrlPerm := EMSOpSts.POpState = enum_EMSOpState.PPC OR EMSOpSts.POpState = enum_EMSOpState.SCADA;\n\tEMSOPSts.QClosedLoopCtrlPerm := EMSOpSts.QOpState = enum_EMSOpState.PPC OR EMSOpSts.QOpState = enum_EMSOpState.SCADA;\nEND_IF\n*)\n\n\n(*\n// -------- Determine comms/health --------\nPPCReady\t:= PPC_GVL.CommOK;\nSCADAReady\t:= SCADA_GVL.CommOK;\nCommFault   := NOT (PPCReady OR SCADAReady);\n\n// -------- No comms: force safe fallback --------\nIF CommFault THEN\n    // Plant-level safe state\n    EMSCmd.OpCmd   := TBE_EMS_DTs.enum_LineUp_OpCmd.STOP;\n    EMSCmd.State   := TBE_EMS_DTs.enum_EMS_State.FAULT;     \n    EMSCmd.PAuto   := FALSE;\n    EMSCmd.Psp     := 0.0;\n    EMSCmd.QAuto   := FALSE;\n    EMSCmd.Qsp     := 0.0;\n\n    // Unit-level safe state\n    FOR i := 0 TO SiteConstants.NumUnits DO\n        LineUpCmd[i].OpCmd  := TBE_EMS_DTs.enum_LineUp_OpCmd.STOP;\n\t\tLineUpCmd[i].PAuto \t:= FALSE;\n        LineUpCmd[i].Psp \t:= 0.0;\n\t\tLineUpCmd[i].QAuto \t:= FALSE;\n        LineUpCmd[i].Qsp \t:= 0.0;\n        // TODO: reset any other per-unit latches if required by your sequence\n    END_FOR;\n\n    CurrentModeSource := FALSE; // treat as manual but safe-shutdown\nELSIF PPCReady AND NOT SCADAReady THEN\n\t // Plant-follow PPC Only\n    EMSCmd   := PPC_CmdInputs;\n\n    // LineUp-level follows PPC Only and PAuto/ QAuto force to TREUE\n    FOR i := 0 TO SiteConstants.NumUnits DO\n        LineUpCmd[i].OpCmd  \t\t:= EMSCmd.OpCmd;\n\t\tLineUpCmd[i].SoCMode  \t\t:= EMSCmd.SoCMode;\n\t\tLineUpCmd[i].Psp  \t\t\t:= EMSCmd.Psp;\n\t\tLineUpCmd[i].Qsp  \t\t\t:= EMSCmd.Qsp;\n\t\tLineUpCmd[i].SoCBalancing  \t:= EMSCmd.SoCBalancing;\n\t\tLineUpCmd[i].PAuto \t:= TRUE;\n\t\tLineUpCmd[i].QAuto \t:= TRUE;\n        // TODO: reset any other per-unit latches if required by your sequence\n    END_FOR;\n\t\n\tCurrentModeSource := TRUE;\nELSIF NOT PPCReady AND SCADAReady THEN\n\t // Plant-follow SCADA Only\n    EMSCmd   := HMI_CmdInputs;\n\n    // LineUp-level follows SCADA Only\n    FOR i := 0 TO SiteConstants.NumUnits DO\n\t\tLineUpCmd[i].OpCmd  \t:= EMSCmd.OpCmd;\n\t\tLineUpCmd[i].SoCMode  \t:= EMSCmd.SoCMode;\n\t\t// Selecting Active Power Setpoint inputs from plant level or lineup level\n\t\tIF HMI_LineUpInputs[i].PAuto THEN\t\t\n\t\t\tLineUpCmd[i].Psp \t\t\t:= EMSCmd.Psp;\n\t\t\tLineUpCmd[i].SoCBalancing \t:= EMSCmd.SoCBalancing;\n\t\tELSE\n\t\t\tLineUpCmd[i].Psp \t:= HMI_LineUpInputs[i].Psp;\n\t\tEND_IF\n\t\t// Selecting Reactive Power Setpoint inputs from plant level or lineup level\n\t\tIF LineUpCmd[i].QAuto THEN\n\t\t\tLineUpCmd[i].Qsp \t:= EMSCmd.Qsp;\n\t\tELSE\n\t\t\tLineUpCmd[i].Qsp \t:= HMI_LineUpInputs[i].Qsp;\n\t\tEND_IF\n    END_FOR;\n\tCurrentModeSource := FALSE;\nELSE\n\tEMSCmd.OpCmd  \t:= HMI_CmdInputs.OpCmd;\n\tEMSCmd.SoCMode  := HMI_CmdInputs.SoCMode;\n\tEMSCmd.PAuto  \t:= HMI_CmdInputs.PAuto;\n\tEMSCmd.QAuto  \t:= HMI_CmdInputs.QAuto;\n\t\n\tIF EMSCmd.PAuto AND EMSCmd.QAuto THEN\n\t\t// Plant-follow PPC\n    \tEMSCmd.Psp := PPC_CmdInputs.Psp;\n\t\tEMSCmd.Qsp := PPC_CmdInputs.Qsp;\n\t\tCurrentModeSource := TRUE;\n\tELSIF EMSCmd.PAuto AND NOT EMSCmd.QAuto THEN\n\t\t// Plant-follow PPC except reactive power setpoints\n    \tEMSCmd.Psp := PPC_CmdInputs.Psp;\n\t\tEMSCmd.Qsp := HMI_CmdInputs.Qsp;\n\t\tCurrentModeSource := TRUE;\n\tELSIF NOT EMSCmd.PAuto AND EMSCmd.QAuto THEN\n\t\t// Plant-follow PPC except active power setpoints\n\t\tEMSCmd.Psp := HMI_CmdInputs.Psp;\n\t\tEMSCmd.Qsp := PPC_CmdInputs.Qsp;\n\t\tCurrentModeSource := TRUE;\n\tELSE\n\t\t// Plant-follow SCADA/HMI\n\t\tEMSCmd.Psp := HMI_CmdInputs.Psp;\n\t\tEMSCmd.Qsp := HMI_CmdInputs.Qsp;\n\t\tCurrentModeSource := FALSE;\n\tEND_IF\n\t\t// LineUp-level follows PPC \n\tFOR i := 0 TO SiteConstants.NumUnits DO\n\t\tLineUpCmd[i].OpCmd \t\t:= EMSCmd.OpCmd;\n\t\tLineUpCmd[i].SoCMode  \t:= EMSCmd.SoCMode;\n\t\tIF EMSCmd.PAuto AND EMSCmd.QAuto THEN\n\t\t\tLineUpCmd[i].PAuto := EMSCmd.PAuto;\n\t\t\tLineUpCmd[i].QAuto := EMSCmd.QAuto;\n\t\tELSE\n\t\t\tLineUpCmd[i].PAuto :=  HMI_LineUpInputs[i].PAuto;\n\t\t\tLineUpCmd[i].QAuto :=  HMI_LineUpInputs[i].QAuto;\n\t\tEND_IF\n\t\t// Setpoints follow PPC or SCADA\n\t\t// Selecting Active Power Setpoint inputs from plant level or lineup level\n\t\tIF HMI_LineUpInputs[i].PAuto THEN\n\t\t\tLineUpCmd[i].Psp \t\t\t:= EMSCmd.Psp;\n\t\t\tLineUpCmd[i].SoCBalancing \t:= EMSCmd.SoCBalancing;\n\t\tELSE\n\t\t\tLineUpCmd[i].Psp \t:= HMI_LineUpInputs[i].Psp;\n\t\tEND_IF\n\t\t// Selecting Reactive Power Setpoint inputs from plant level or lineup level\n\t\tIF HMI_LineUpInputs[i].QAuto THEN\n\t\t\tLineUpCmd[i].Qsp \t:= EMSCmd.Qsp;\n\t\tELSE\n\t\t\tLineUpCmd[i].Qsp \t:= HMI_LineUpInputs[i].Qsp;\n\t\tEND_IF\n\tEND_FOR;\nEND_IF;\n\n\n// -------- Optional: STOP priority --------\n// If EMSCmd.Stop (if present) or Mode.State=Fault, ensure Start=FALSE and En = FALSE (already covered above)\n*)\n","LineInfoPersistence":"(string)86a39085-a4f0-40d8-a158-b791209b1435_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n| Terabase Energy - Energy Management System\n| Battery Control Program for input selection and condition checks\n*)\nPROGRAM pg_EMSOpModeCtrl\nVAR_INPUT\n\tHMIInputs\t\t\t: dt_HMIInputs;\t\t//Plant-level inputs to EMS from HMI\n\tMeterFbk\t\t\t: dt_MeterFbk; \n\tEMSVFbk\t\t\t\t: dt_EMSVFbk; \n\tEMSPlantAlarms\t\t: dt_EMSPlantAlarms; \n\t\n    //HMI_CmdInputs    : TBE_EMS_DTs.dt_EMS_Cmd;                   \t\t\t\t\t\t// HMI Inputs (SCADA/manual)\n    //HMI_LineUpInputs : ARRAY[0..SiteConstants.NumUnits] OF TBE_EMS_DTs.dt_LineUp_Cmd;\t// HMI Line Up Command Inputs\n    //PPC_CmdInputs    : TBE_EMS_DTs.dt_EMS_Cmd;                  \t\t\t\t\t\t// PPC Inputs (auto)\nEND_VAR\n\nVAR_OUTPUT\n\tEMSOpSts\t\t\t: dt_EMSOpSts;\t\t//EMS Operating Status Output\n    //EMSCmd             \t: TBE_EMS_DTs.dt_EMS_Cmd;                 \t\t\t\t\t\t// EMS Output Command (plant-level)\n    //LineUpCmd          \t: ARRAY[0..SiteConstants.NumUnits] OF TBE_EMS_DTs.dt_LineUp_Cmd;// Line Up Output Command\n    //CurrentModeSource  \t: BOOL;                                          \t\t\t\t// TRUE=Auto/PPC, FALSE=Manual/SCADA\nEND_VAR\n\nVAR\n    //i                  \t: UINT;                                          \t\t\t\t// Unit index\n\tSCADAReady\t\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t// SCADA Communication Ready\n\t//PPCReady\t\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t// PPC Communication Ready\n    //CommFault         \t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t// Communication Fault with SCADA or PPC\nEND_VAR","LineInfoPersistence":"(string)86a39085-a4f0-40d8-a158-b791209b1435_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)633","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}