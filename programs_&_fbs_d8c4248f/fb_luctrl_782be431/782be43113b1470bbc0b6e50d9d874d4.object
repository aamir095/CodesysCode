{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)782be431-13b1-470b-bc0b-6e50d9d874d4","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_LUCtrl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine LU POpState\nIF ((EMSOpSts.POpState = enum_EMSOpState.Fault OR EMSOpSts.POpState = enum_EMSOpState.Stop) AND LUAlarms.AlarmLevel <> enum_AlarmLevel.Critical) OR LUHMIInputs.OpModeCmd = enum_LUOpModeCmd.Estop THEN\n\t//EMS is stopped or faulted - set LU op state to Stop\n\tLUCtrlSts.POpState := enum_LUOpState.Stop;\nELSIF LUHMIInputs.PAutoEn AND LUAlarms.AlarmLevel <> enum_AlarmLevel.Critical THEN\n\tLUCtrlSts.POpState := enum_LUOpState.Auto;\nELSIF NOT LUHMIInputs.PAutoEn AND LUAlarms.AlarmLevel <> enum_AlarmLevel.Critical THEN\n\tLUCtrlSts.POpState := enum_LUOpState.Manual;\nELSE\n\t//Critical fault active, set state to faulted\n\tLUCtrlSts.POpState := enum_LUOpState.Fault;\nEND_IF\n\n//Determine LU QOpState\nIF ((EMSOpSts.QOpState = enum_EMSOpState.Fault OR EMSOpSts.QOpState = enum_EMSOpState.Stop) AND LUAlarms.AlarmLevel <> enum_AlarmLevel.Critical) OR LUHMIInputs.OpModeCmd = enum_LUOpModeCmd.Estop THEN\n\t//EMS is stopped or faulted - set LU op state to Stop\n\tLUCtrlSts.QOpState := enum_LUOpState.Stop;\nELSIF LUHMIInputs.QAutoEn AND LUAlarms.AlarmLevel <> enum_AlarmLevel.Critical THEN\n\tLUCtrlSts.QOpState := enum_LUOpState.Auto;\nELSIF NOT LUHMIInputs.QAutoEn AND LUAlarms.AlarmLevel <> enum_AlarmLevel.Critical THEN\n\tLUCtrlSts.QOpState := enum_LUOpState.Manual;\nELSE\n\t//Critical fault active, set state to faulted\n\tLUCtrlSts.QOpState := enum_LUOpState.Fault;\nEND_IF\n\n//Determine run command\nIF LUCtrlSts.QOpState =  enum_LUOpState.Fault  OR (LUCtrlSts.QOpState =  enum_LUOpState.Stop AND LUCtrlSts.POpState = enum_LUOpState.Stop )  OR LUCtrlSts.POpState = enum_LUOpState.Fault THEN\n\tLUCmds.Run := FALSE;\nELSIF LUCtrlSts.QOpState = enum_LUOpState.Auto OR LUCtrlSts.POpState = enum_LUOpState.Auto THEN\n\tLUCmds.Run := TRUE;\nELSIF LUCmds.Run := LUHMIInputs.OpModeCmd = enum_LUOpModeCmd.Run THEN\n\tLUCmds.Run := TRUE;\nELSE\n\tLUCmds.Run := FALSE;\nEND_IF\n\n//Assign active power setpoint based on LU POpState\nIF LUCtrlSts.POpState = enum_LUOpState.Auto THEN\n\tLUCmds.PSp := PSpPlant;\nELSIF LUCtrlSts.POpState = enum_LUOpState.Manual THEN\n\tLUCmds.PSp := LUHMIInputs.Psp;\nELSE\n\t//LU is stopped or faulted, Set setpoint to 0\n\tLUCmds.PSp := 0; \nEND_IF\n\n//Assign reactive power setpoint based on LU QOpState\nIF LUCtrlSts.QOpState = enum_LUOpState.Auto THEN\n\tLUCmds.Qsp := QSpPlant;\nELSIF LUCtrlSts.QOpState = enum_LUOpState.Manual THEN\n\tLUCmds.Qsp := LUHMIInputs.Qsp;\nELSE\n\t//LU is stopped or faulted, Set setpoint to 0\n\tLUCmds.Qsp := 0; \nEND_IF\n\n//Derate Charge/Discharge based on LU Alarm\nDeRateFb( LUAlarms := LUAlarms, PSp := PSpPlant, ChargeDeratePct => PSpDeratedChPT, DischargeDeratePct => PSpDeratedDischPT, ReactiveDeratePct => QSpDeratedPT);\nLUCmds.PSp := LIMIT (PSpDeratedChPT, LUCmds.PSp, PSpDeratedDischPT);\nLUCmds.Qsp := LIMIT (-1*QSpDeratedPT, LUCmds.Qsp, QSpDeratedPT);\n\n//LU P Setpoint Auto Ramp Rate \nRampBlock1(En := TRUE, Auto := LUCtrlSts.POpState = enum_LUOpState.Auto, FreezeUp := FALSE, FreezeDn := FALSE, SP := LUCmds.PSp, PV := LUFbk.InvACPwr, UpLim := LUCfg.PRampUpRt, DnLim := LUCfg.PRampDnRt, TaskTime := TaskTime, Out => PSpTemp); \n//LU Q Setpoint Auto Ramp Rate \nRampBlock2(En := TRUE, Auto := LUCtrlSts.QOpState = enum_LUOpState.Auto, FreezeUp := FALSE, FreezeDn := FALSE, SP := LUCmds.QSp, PV := LUFbk.InvRePwr, UpLim := LUCfg.QRampUpRt, DnLim := LUCfg.QRampDnRt, TaskTime := TaskTime, Out => QSpTemp); \n\n//P-Q Priority Logic, Default Q-Priority\nPQLim(Pin := PSpTemp, Qin := QSpTemp, Smax := 1, PPriority := PPriority, Pout => LUCmds.PSp, Qout => LUCmds.QSp);\n\n//Limit Logic\nLUCmds.PSp := LIMIT(-1, LUCmds.PSp, 1);\nLUCmds.QSp := LIMIT(-1, LUCmds.QSp, 1); \n\n\n//Assign diagnostics\nLUCtrlSts.RunCmd \t:= LUCmds.Run;\nLUCtrlSts.PCmd \t\t:= LUCmds.PSp;\nLUCtrlSts.QCmd \t\t:= LUCmds.QSp;\nLUCtrlSts.PDerate \t:= PQLim.PDerate OR DeRatefb.PDerate;\nLUCtrlSts.QDerate \t:= PQLim.QDerate  OR DeRatefb.QDerate;\n","LineInfoPersistence":"(string)782be431-13b1-470b-bc0b-6e50d9d874d4_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tLU Control Function Block\n*)\nFUNCTION_BLOCK fb_LUCtrl\nVAR_INPUT\n\tLUHMIInputs\t\t\t\t: dt_LUHMIInputs;\n\tPSpPlant\t\t\t\t: REAL;\n\tQSpPlant\t\t\t\t: REAL;\n\tLUAlarms\t\t\t\t: dt_LUAlarms;\n\tEMSOpSts\t\t\t\t: dt_EMSOpSts;\n\tLUCfg\t\t\t\t\t: dt_LUCfg;\n\tLUFbk\t \t\t\t\t: dt_LUFbk;\n\tTaskTime\t\t\t\t: UINT;  \n\tPPriority\t\t\t\t: BOOL;\nEND_VAR\nVAR_OUTPUT\n\tLUCtrlSts\t\t\t\t: dt_LUCtrlSts; \n\tLUCmds\t\t\t\t\t: dt_LUCmds; \nEND_VAR\nVAR\n\tRampBlock1\t\t\t: TBE_POUs.fb_R_LIM;\t\t//Ramp rate block\n\tRampBlock2\t\t\t: TBE_POUs.fb_R_LIM;\t\t//Ramp rate block\n\tPSpTemp\t\t\t\t: REAL;\t\t\t\t\t\t//Temp LU Active Power SP\n\tQSpTemp\t\t\t\t: REAL;\t\t\t\t\t\t//Temp LU Reactive Power SP\n\tPQLim\t\t\t\t: fb_PQLim;\t\t\t\t\t//P/Q Limit Block\n\tDeRateFb\t\t\t: fb_Derate;\t\t\t\t//Dereate P/Q Based on Alarms\n\tPSpDeratedChPT\t\t: REAL;\t\t\t\t\t\t//Temp LU Active Power SP Derated Charging %\n\tPSpDeratedDischPT\t: REAL;\t\t\t\t\t\t//Temp LU Active Power SP Derated Discharging %\n\tQSpDeratedPT\t\t: REAL;\t\t\t\t\t\t//Temp LU Reactive Power SP Derated %\nEND_VAR\n","LineInfoPersistence":"(string)782be431-13b1-470b-bc0b-6e50d9d874d4_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)227","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}