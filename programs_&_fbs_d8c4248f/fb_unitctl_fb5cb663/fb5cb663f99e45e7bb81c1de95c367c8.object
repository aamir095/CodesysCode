{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)fb5cb663-f99e-45e7-bb81-c1de95c367c8","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_UnitCtl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// --- Auto/Manual selection: Active ---\nIF PAutoEn THEN\n    Psp_In     := Psp_EMS;\n    PRampUpRt  := PRampUpRt_EMS;\n    PRampDnRt  := PRampDnRt_EMS;\nELSE\n    Psp_In     := Psp_HMI;\n    PRampUpRt  := PRampUpRt_HMI;\n    PRampDnRt  := PRampDnRt_HMI;\nEND_IF;\n\n// --- Auto/Manual selection: Reactive ---\nIF QAutoEn THEN\n    Qsp_In     := Qsp_EMS;          // fixed\n    QRampUpRt  := QRampUpRt_EMS;    // fixed\n    QRampDnRt  := QRampDnRt_EMS;    // fixed\nELSE\n    Qsp_In     := Qsp_HMI;          // fixed\n    QRampUpRt  := QRampUpRt_HMI;    // fixed\n    QRampDnRt  := QRampDnRt_HMI;    // fixed\nEND_IF;\n\n//Bumpless transfer between Auto/ manual\n\n// --- Sanity & range checks (tune limits as needed) ---\n\nValidPInputs \t:= (ABS(Psp_In) <= ABS(PLim));\nValidQInputs \t:= (ABS(Qsp_In) <= ABS(QLim));\nValidPRInputs   := (PRampUpRt >= 0.0) AND (PRampDnRt >= 0.0) AND (PRampUpRt <= PRampUpRtLim) AND (PRampDnRt <= PRampDnRtLim);\nValidQRInputs\t:= (QRampUpRt >= 0.0) AND (QRampDnRt >= 0.0) AND  (QRampUpRt <= QRampUpRtLim) AND (QRampDnRt <= QRampDnRtLim);\n\n// --- Magnitude check ---\nMagnitudeOK := (Smax >= 0.0) AND (SQRT(Psp_In*Psp_In + Qsp_In*Qsp_In) <= Smax);\n\n// Enable control only if not tripped\nEnableControl := NOT Trip;\n\n// --- Received flags: make these real inputs or set defaults --- To be deleted in the final template and replace with quality check below\nIF EnableControl THEN\n    // If you do not have quality bits yet, assume received = TRUE\n    PspReceived     := TRUE;\n    QspReceived     := TRUE;\n    PRampRtReceived := TRUE;\n    QRampRtReceived := TRUE;\nELSE\n    PspReceived     := FALSE;\n    QspReceived     := FALSE;\n    PRampRtReceived := FALSE;\n    QRampRtReceived := FALSE;\nEND_IF;\n\n(*\n// Quality check for Set point tags\n// Active Power Setpoint\nIF NOT Psp_In.quality = good THEN\n\tPspReceived := FALSE; \nEND_IF\n// Reactive Power Setpoint\nIF NOT Qsp_In.quality = good THEN\n\tQspReceived := FALSE;\nEND_IF\n// Active Power Ramp Rate\nIF NOT PRampUpRt.quality = good AND PRampDnRt.quality = good THEN\n\tPRampRtReceived := FALSE;\nEND_IF\n// Reactive Power Ramp Rate\nIF NOT QRampUpRt.quality = good AND QRampDnRt.quality = good THEN\n\tQRampRtReceived := FALSE;\nEND_IF\n*)\n\n// --- Process setpoints with priority & projection ---\nIF (NOT EnableControl) OR (NOT PspReceived) THEN\n    ValidPsp := 0.0;\n    PspReady := FALSE;\nELSIF ValidPInputs AND (MagnitudeOK OR PspPri) THEN\n\t//passing the active power setpoint if valid and the Magnitude check pass or active power priority\n    ValidPsp := Psp_In;\n    PspReady := TRUE;\nELSE\n    ValidPsp := PLim;\n    PspReady := TRUE;   // consistent\nEND_IF;\n\nIF (NOT EnableControl) OR (NOT QspReceived) THEN\n    ValidQsp := 0.0;\n    QspReady := FALSE;\nELSIF ValidQInputs AND (MagnitudeOK OR NOT PspPri) THEN\n\t//passing the reactive power setpoint if valid and the Magnitude check pass or no active power priority\n    ValidQsp := Qsp_In;\n    QspReady := TRUE;\nELSE\n    ValidQsp := QLim;\n    QspReady := TRUE;   // consistent\nEND_IF;\n\n// Apply Smax with priority (vector projection)\nPQLimit(Pin := ValidPsp, Qin := ValidQsp, Smax := Smax, PPriority := PspPri);\n\nValidPsp := PQLimit.Pout;\nValidQsp := PQLimit.Qout;\n\n// --- Process ramp rates ---\nIF (NOT EnableControl) OR (NOT PRampRtReceived) THEN\n    ValidPRampUpRt := 0.0;\n    ValidPRampDnRt := 0.0;\nELSIF ValidPRInputs THEN\n    ValidPRampUpRt := PRampUpRt;\n    ValidPRampDnRt := PRampDnRt;\nELSE\n    ValidPRampUpRt := PRampUpRtLim;\n    ValidPRampDnRt := PRampDnRtLim;\nEND_IF;\n\nIF (NOT EnableControl) OR (NOT QRampRtReceived) THEN\n    ValidQRampUpRt := 0.0;\n    ValidQRampDnRt := 0.0;\nELSIF ValidQRInputs THEN\n    ValidQRampUpRt := QRampUpRt;\n    ValidQRampDnRt := QRampDnRt;\nELSE\n    ValidQRampUpRt := QRampUpRtLim;   \n    ValidQRampDnRt := QRampDnRtLim;   \nEND_IF;\n\nPRampReady := EnableControl AND ValidPRInputs;\nQRampReady := EnableControl AND ValidQRInputs;\n//Ramp Rate Control and SoC\n\n// Outputs\nPsp_Out := ValidPsp;\nQsp_Out := ValidQsp;","LineInfoPersistence":"(string)fb5cb663-f99e-45e7-bb81-c1de95c367c8_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tTerabase Energy - Energy Managment System Battery Unit Control Function Block\n*)\nFUNCTION_BLOCK fb_UnitCtl\nVAR_INPUT\n\tPAutoEn\t\t\t: BOOL;\t // TRUE: Active power setpoint from EMS - FALSE: Active power setpoint from SCADA/ HMI\n\tQAutoEn\t\t\t: BOOL;\t // TRUE: Rective power setpoint from EMS - FALSE: Reactive power setpoint from SCADA/ HMI\n\tPsp_EMS      \t: REAL;  // Active power setpoint from EMS (p.u.)\n    Qsp_EMS      \t: REAL;  // Reactive power setpoint from EMS(p.u.)\n\tPsp_HMI      \t: REAL;  // Active power setpoint from HMI(p.u.)\n    Qsp_HMI      \t: REAL;  // Reactive power setpoint from HMI(p.u.)\n\tPRampUpRt_EMS   : REAL;  // Active power ramp up rate from EMS (p.u./s)\n\tPRampDnRt_EMS   : REAL;  // Active power ramp down rate from EMS(p.u./s)\n    QRampUpRt_EMS   : REAL;  // Reactive power ramp up rate from EMS(p.u./s)\n\tQRampDnRt_EMS   : REAL;  // Reactive power ramp down rate from EMS(p.u./s)\n\tPRampUpRt_HMI   : REAL;  // Active power ramp up rate from HMI/SCADA (p.u./s)\n\tPRampDnRt_HMI   : REAL;  // Active power ramp down rate from HMI/SCADA(p.u./s)\n    QRampUpRt_HMI   : REAL;  // Reactive power ramp up rate from HMI/SCADA(p.u./s)\n\tQRampDnRt_HMI   : REAL;  // Reactive power ramp down rate from HMI/SCADA(p.u./s)\n    Smax         \t: REAL;  // Apparent power limit (p.u.)\n    Trip         \t: BOOL; // Trip condition\n\tPspPri\t\t\t: BOOL; // TRUE: Active Power Setpoint priority; FALSE: Reacitve Power Setpoint priority\n    SoC_Bal_Enabled : BOOL; // SoC balancing enabled\n\tPLim\t\t\t: REAL; // Active Power Limit Setpoints in p.u\n\tQLim\t\t\t: REAL; // Reactive Power Limit Setpoints in p.u\n\tPRampUpRtLim\t\t: REAL; // Active Power Ramp Up Rate Limit\n\tPRampDnRtLim\t\t: REAL; // Active Power Ramp Down Rate Limit\n\tQRampUpRtLim\t\t: REAL; // Reactive Power Ramp Up Rate Limit\n\tQRampDnRtLim\t\t: REAL; // Reactive Power Ramp Down Rate Limit\nEND_VAR\nVAR_OUTPUT\n\tPsp_Out      \t: REAL;  // Active power setpoint (p.u.)\n    Qsp_Out      \t: REAL;  // Reactive power setpoint (p.u.)\nEND_VAR\nVAR\n\tPsp_In      \t: REAL;  // Active power setpoint (p.u.)\n    Qsp_In      \t: REAL;  // Reactive power setpoint (p.u.)\n\tPRampUpRt    \t: REAL;  // Active power ramp up rate (p.u./s)\n\tPRampDnRt    \t: REAL;  // Active power ramp down rate (p.u./s)\n    QRampUpRt    \t: REAL;  // Reactive power ramp up rate (p.u./s)\n\tQRampDnRt    \t: REAL;  // Reactive power ramp down rate (p.u./s)\n\tPspReceived\t\t: BOOL; //Active power setpoints receviced\n\tQspReceived\t\t: BOOL; //Reactive power setpoints receviced\n\tPRampRtReceived\t: BOOL; //Active Power Ramp Rate receviced\n\tQRampRtReceived\t: BOOL; //Active Power Ramp Rate Rate receviced\n\tValidPsp    \t: REAL;\t//Valid active power setpoint\n    ValidQsp    \t: REAL; //Valid reactive power setpoint\n    ValidPRampUpRt  : REAL; //Valid active power ramp up rate\n\tValidPRampDnRt  : REAL; //Valid active power ramp down rate\n    ValidQRampUpRt  : REAL; //Valid reactive power ramp up rate\n\tValidQRampDnRt  : REAL; //Valid reactive power ramp down rate\n\tValidPInputs\t: BOOL;\n\tValidQInputs\t: BOOL;\n\tValidPRInputs\t: BOOL;\n\tValidQRInputs\t: BOOL;\n\tValidInputs \t: BOOL; //Valid for power ramp rates and power setpoints\n    MagnitudeOK \t: BOOL; //Valid power setpoints condition\n    EnableControl \t: BOOL; //Checking for the Unit Condition\n\tPspReady    \t: BOOL;\t//Active power setpoint ready for the logic\n    QspReady    \t: BOOL; //Reactive power setpoint ready for the logic\n    PRampReady   \t: BOOL; //Power ramp rate ready for the logic\n\tQRampReady   \t: BOOL; //Power ramp rate ready for the logic\n\tPQLimit\t\t\t: fb_PQLim;\nEND_VAR\n","LineInfoPersistence":"(string)fb5cb663-f99e-45e7-bb81-c1de95c367c8_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)379","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}