{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)8e23cae0-586f-45cc-82f1-21a0e32c80cd","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_SoCScale","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)PspPlant_Sum := 0;\n\nFOR i := 0 TO SiteConstants.NumLineups BY 1 DO\n\tPspPlant_Sum := PspPlant_Sum + PspLU_In[i] * PnomLU[i];\nEND_FOR\n\nIF (PspPlant_Sum <> 0.0 AND PnomPlant <>0 ) THEN\n    // Example: compare total plant setpoint vs total LU sum \n    Err := PspPlant * PnomPlant - PspPlant_Sum /(PnomPlant * SiteConstants.NumLineups) ;\n    IF ABS(Err) > Tolerance THEN\n        // Compute scale factor once\n        ScaleFactor  := (PspPlant * PnomPlant) / PspPlant_Sum;\n\tELSE\n\t\tScaleFactor := 1;\n    END_IF;\n\tFOR i := 0 TO SiteConstants.NumLineups BY 1 DO\n\t\tPspLU_Out[i] := PspLU_In[i] * ScaleFactor;\n\tEND_FOR\nELSE\n\tFOR i := 0 TO SiteConstants.NumLineups BY 1 DO\n\tPspLU_Out[i] := PspLU_In[i];\n\tEND_FOR\nEND_IF;","LineInfoPersistence":"(string)8e23cae0-586f-45cc-82f1-21a0e32c80cd_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_SoCScale\nVAR_INPUT\n\tSumPsp \t\t: REAL;\n\tPspPlant\t: REAL;\n\tPnomPlant\t: REAL;\n\tPspLU_In\t: ARRAY[0..SiteConstants.NumLineups] OF REAL;\n\tPnomLU\t\t: ARRAY[0..SiteConstants.NumLineups] OF REAL;\n\tTolerance   : REAL;\nEND_VAR\nVAR_OUTPUT\n\tPspLU_Out\t:  ARRAY[0..SiteConstants.NumLineups] OF REAL;\nEND_VAR\nVAR\n    ScaleFactor \t: REAL;\n    Err         \t: REAL;\n\ti\t\t\t\t: UINT;\n\tPspPlant_Sum\t: REAL;\nEND_VAR\n","LineInfoPersistence":"(string)8e23cae0-586f-45cc-82f1-21a0e32c80cd_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)213","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}