{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)26137d69-8eab-45f0-adfd-663a58f96473","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_EMSOp_Ctl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// Initialize output\nPCtl_Out.Psp \t\t:= EMSCmd.Psp;\nPCtl_Out.PRampUpRt \t:= EMSCfg.PRampUpRt;\nPCtl_Out.PRampDnRt \t:= EMSCfg.PRampDnRt;\nPCtl_Out.PAvailMax \t:= EMSCfg.PAvailMax;\nPCtl_Out.PAvailMin \t:= EMSCfg.PAvailMin;\nPCtl_Out.Pmax_POI \t:= EMSCfg.Pmax_POI;\nPCtl_Out.Pmin_POI \t:= EMSCfg.Pmin_POI;\nPctl_Out.Cfg \t\t:= EMSCfg.AcPwrCfg;\n\nQCtl_Out.Qsp \t\t:= EMSCmd.Qsp;\nQCtl_Out.QRampUpRt \t:= EMSCfg.QRampUpRt;\nQCtl_Out.QRampDnRt \t:= EMSCfg.QRampDnRt;\nQctl_Out.Cfg \t\t:= EMSCfg.RePwrCfg;\n\n\n// Selecting between auto-manual active power control\n// adding the meter feedbacks or PCS feedback to ensure it is the closed loop control\n// consider to move back to open loop if not satisfy\nIF EMSCmd.PAuto = TRUE THEN\n\tPCtl_Out.PAuto := TRUE;\nELSE\n\tPCtl_Out.PAuto := FALSE;\nEND_IF\n\n// Selecting between auto-manual active power control\nIF EMSCmd.QAuto = TRUE THEN\n\tQCtl_Out.QAuto := TRUE;\nELSE\n\tQCtl_Out.QAuto := FALSE;\nEND_IF\n\n// Selecting between power distribution mode 1 and SoC balancing mode 2\nIF EMSCmd.SoCBalancing THEN\n\tPCtl_Out.SoC_Bal_Enable := TRUE;\nELSE\n\tPCtl_Out.SoC_Bal_Enable := FALSE;\nEND_IF\n\n//UnitFbk and UnitCfg to support mode 2 SoC balancing later closed loop control requirement","LineInfoPersistence":"(string)26137d69-8eab-45f0-adfd-663a58f96473_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tTerabase Energy - Energy Managment System Battery Operational Control Program for P-Q Setpoints of whole plant\n*)\nPROGRAM pg_EMSOp_Ctl\nVAR_INPUT\n\tEMSCmd\t\t: TBE_EMS_DTs.dt_EMS_Cmd;\t\t\t\t\t\t\t\t\t\t\t\t//EMS Input Commands\n\tEMSCfg\t\t: TBE_EMS_DTs.dt_EMS_Cfg;\t\t\t\t\t\t\t\t\t\t\t\t//EMS Input Configs\nEND_VAR\nVAR_OUTPUT\n\tPCtl_Out \t\t: TBE_EMS_DTs.dt_EMS_PCtl;\t\t\t\t\t\t\t//Acitve Power Control Output\n\tQCtl_Out \t\t: TBE_EMS_DTs.dt_EMS_QCtl;\t\t\t\t\t\t\t//Reactive Power Control Output\nEND_VAR\nVAR\nEND_VAR","LineInfoPersistence":"(string)26137d69-8eab-45f0-adfd-663a58f96473_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)198","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}