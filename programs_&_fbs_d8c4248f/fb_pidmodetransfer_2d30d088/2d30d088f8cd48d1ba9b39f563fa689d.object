{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)2d30d088-f8cd-48d1-ba9b-39f563fa689d","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_PIDModeTransfer","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// One-time init to avoid undefined SP_Int\nIF NOT InitDone THEN\n    SP_Int := SP_In;\n    InitDone := TRUE;\nEND_IF\n\n// Detect transition from closed loop -> open loop\nFallEdge(CLK := ClosedLoopCtrlEn);\n\nIF FallEdge.Q THEN\n    // On transfer to open loop, force SP to PV to avoid a step in error at the handoff\n    SP_Int := PV;\nEND_IF\n\nIF ClosedLoopCtrlEn THEN\n    // In closed loop, pass through normal setpoint\n    SP_Int := SP_In;\n    SP_Out := SP_Int;\nELSE\n    // In open loop: either hold SP at captured PV, or optionally ramp toward SP_In\n    IF RampInOpenLoop THEN\n        Err := SP_In - SP_Int;\n\n        IF ABS(Err) > Eps THEN\n            Step := ABS(RampRate) * ABS(CycleTime);\n\n            IF ABS(Err) <= Step THEN\n                SP_Int := SP_In;\n            ELSE\n                IF Err > 0.0 THEN\n                    SP_Int := SP_Int + Step;\n                ELSE\n                    SP_Int := SP_Int - Step;\n                END_IF\n            END_IF\n        ELSE\n            SP_Int := SP_In;\n        END_IF\n    END_IF\n\n    SP_Out := SP_Int;\nEND_IF","LineInfoPersistence":"(string)2d30d088-f8cd-48d1-ba9b-39f563fa689d_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Handling the setpoints for PID controller to ensure bumpless transfer\nFUNCTION_BLOCK fb_PIDModeTransfer\nVAR_INPUT\n    ClosedLoopCtrlEn : BOOL;   // TRUE = closed loop, FALSE = open loop\n    SP_In            : REAL;   // Operator/remote setpoint\n    PV               : REAL;   // Process value\n    CycleTime        : REAL;   // [ms]\n    RampRate         : REAL;   // [units/ms]  (optional use)\n    Eps              : REAL := 0.001;\n    RampInOpenLoop   : BOOL := FALSE; // if TRUE, ramp SP_Out while open loop\nEND_VAR\nVAR_OUTPUT\n    SP_Out           : REAL;   // Setpoint to PID (or for display)\nEND_VAR\nVAR\n    FallEdge         : F_TRIG;\n    SP_Int           : REAL;\n    Step             : REAL;\n    Err              : REAL;\n    InitDone         : BOOL;\nEND_VAR","LineInfoPersistence":"(string)2d30d088-f8cd-48d1-ba9b-39f563fa689d_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)127","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}