{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)26b08cc7-c9cc-4876-b921-58cc385d87eb","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_Derate","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)doChargeDerate := PSp <= 0 AND (LUAlarms.ACCurrent.LoLo OR  LUAlarms.ContTemp.HiHi OR  LUAlarms.ContTemp.LoLo OR  LUAlarms.DCCurrent.LoLo OR LUAlarms.DCVoltage.HiHi OR LUAlarms.SOC.HiHi);\ndoDischargeDerate :=  PSp >= 0 AND (LUAlarms.ACCurrent.HiHi OR LUAlarms.ContTemp.HiHi OR LUAlarms.ContTemp.LoLo OR LUAlarms.DCCurrent.HiHi OR LUAlarms.DCVoltage.LoLo OR LUAlarms.SOC.LoLo);\ndoReactiveDerate := LUAlarms.ACVoltage.HiHi OR LUAlarms.ACVoltage.LoLo;\n// Run timers (large PT so ET can grow while IN is TRUE)\ntCharge   (IN := doChargeDerate,    PT := T#1D);\ntDischarge(IN := doDischargeDerate, PT := T#1D);\ntReactive (IN := doReactiveDerate,  PT := T#1D);\n// ---- Charge ----\nIF tCharge.ET = T#0s THEN\n    ChargeDeratePct := -1.0;\n    AnyChargeDerate := FALSE;\nELSIF tCharge.ET < T#60s THEN\n    ChargeDeratePct := -0.75;\n    AnyChargeDerate := TRUE;\nELSIF tCharge.ET < T#120s THEN\n    ChargeDeratePct := -0.50;\n    AnyChargeDerate := TRUE;\nELSE\n    ChargeDeratePct := 0.0;\n    AnyChargeDerate := TRUE;\nEND_IF;\n\n// ---- Discharge ----\nIF tDischarge.ET = T#0s THEN\n    DischargeDeratePct := 1.0;\n    AnyDischargeDerate := FALSE;\nELSIF tDischarge.ET < T#60s THEN\n    DischargeDeratePct := 0.75;\n    AnyDischargeDerate := TRUE;\nELSIF tDischarge.ET < T#120s THEN\n    DischargeDeratePct := 0.50;\n    AnyDischargeDerate := TRUE;\nELSE\n    DischargeDeratePct := 0.0;\n    AnyDischargeDerate := TRUE;\nEND_IF;\n\n// ---- Reactive ----\nIF tReactive.ET = T#0s THEN\n    ReactiveDeratePct := 1.0;\n    AnyReactiveDerate := FALSE;\nELSIF tReactive.ET < T#60s THEN\n    ReactiveDeratePct := 0.75;\n    AnyReactiveDerate := TRUE;\nELSIF tReactive.ET < T#120s THEN\n    ReactiveDeratePct := 0.50;\n    AnyReactiveDerate := TRUE;\nELSE\n    ReactiveDeratePct := 0.0;\n    AnyReactiveDerate := TRUE;\nEND_IF;\n\nPDerate := AnyDischargeDerate OR AnyChargeDerate;\nQDerate := AnyReactiveDerate;\n","LineInfoPersistence":"(string)26b08cc7-c9cc-4876-b921-58cc385d87eb_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_Derate\nVAR_INPUT\n\t LUAlarms\t\t\t: dt_LUAlarms;\n\t PSp \t\t\t\t: REAL; \t//LU Level Active Power Setpoint\nEND_VAR\nVAR_OUTPUT\n\t// Derate factors (1.0 = 100%, 0.75 = 75%)\n    ChargeDeratePct    : REAL;\n    DischargeDeratePct : REAL;\n    ReactiveDeratePct  : REAL;\n\tPDerate\t\t\t   : BOOL;\n\tQDerate\t\t\t   : BOOL;\nEND_VAR\nVAR\n    // OR'd conditions per derate type\n    doChargeDerate    : BOOL;\n    doDischargeDerate : BOOL;\n    doReactiveDerate  : BOOL;\n\n    // Timers per derate type\n    tCharge    : TON;\n    tDischarge : TON;\n    tReactive  : TON;\n\t\n\tAnyChargeDerate     : BOOL;\n    AnyDischargeDerate  : BOOL;\n    AnyReactiveDerate   : BOOL;\nEND_VAR\n","LineInfoPersistence":"(string)26b08cc7-c9cc-4876-b921-58cc385d87eb_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)114","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}