{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)bb27f359-1ae6-4a20-980e-4bdb3a26fc21","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_Alarms","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine LU-level alarms\nFOR i := 0 TO SiteConstants.NumLineups BY 1 DO\n\tIF i > 0 THEN\n\t\tIF LUFbk[i].AlmComm THEN\n\t\t\tLUOfflineCount := LUOfflineCount + 1;\n\t\tEND_IF\n\t\t//Communication Alarm\n\t\tLUAlarms[i].Offline := LUFbk[i].AlmComm;\n\t\t//Fire suppression Alarm\n\t\tLUAlarms[i].FireSuppAlarm := LUFbk[i].AlmFire;\n\t\t//HVAC Alarm\n\t\tLUAlarms[i].HVACAlarm := LUFbk[i].AlmHVAC;\n\t\n\t\t// Container Door Open\n\t\tLUAlarms[i].ContDoorOpen := LUFbk[i].ContDoorOpen;\n\t\n\t\t// Fire suppression system and HVAC System Fault\n\t\tIF LUFbk[i].StsFireSupp = TBE_EMS_DTs.enum_FireSupp_Sts.FAULT OR LUFbk[i].StsHVAC = TBE_EMS_DTs.enum_HVAC_Sts.FAULT THEN\n\t\t\tLUAlarms[i].AuxSysFault := TRUE;\n\t\tELSE\n\t\t\tLUAlarms[i].AuxSysFault := FALSE;\n\t\tEND_IF\n\t\n\t\t//DC Voltage Alarm\n\t\tLUDCVAlarm[i](En := NOT LUFbk[i].AlmComm,\n\t\t\tCfg_LoLoTime := LUAlarmCfg[i].ThreshTime, \n\t\t\tCfg_LoTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_LoLoLmt := LUAlarmCfg[i].DCVoltageFbk.LoLo,\n\t\t\tCfg_LoLmt := LUAlarmCfg[i].DCVoltageFbk.Lo,\n\t\t\tCfg_HiLmt := LUAlarmCfg[i].DCVoltageFbk.Hi,\n\t\t\tCfg_HiHiLmt := LUAlarmCfg[i].DCVoltageFbk.HiHi,\n\t\t\tIn := LUFbk[i].InvDCV,\n\t\t\tLoLo => LUAlarms[i].DCVoltage.LoLo,\n\t\t\tLo => LUAlarms[i].DCVoltage.Lo,\n\t\t\tHi => LUAlarms[i].DCVoltage.Hi,\n\t\t\tHiHi => LUAlarms[i].DCVoltage.HiHi);\n\t\t\t\n\t\t//DC Current Alarm\n\t\tLUDCAAlarm[i](En := NOT LUFbk[i].AlmComm,\n\t\t\tCfg_LoLoTime := LUAlarmCfg[i].ThreshTime, \n\t\t\tCfg_LoTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_LoLoLmt := LUAlarmCfg[i].DCCurrentFbk.LoLo,\n\t\t\tCfg_LoLmt := LUAlarmCfg[i].DCCurrentFbk.Lo,\n\t\t\tCfg_HiLmt := LUAlarmCfg[i].DCCurrentFbk.Hi,\n\t\t\tCfg_HiHiLmt := LUAlarmCfg[i].DCCurrentFbk.HiHi,\n\t\t\tIn := LUFbk[i].InvDCA,\n\t\t\tLoLo => LUAlarms[i].DCCurrent.LoLo,\n\t\t\tLo => LUAlarms[i].DCCurrent.Lo,\n\t\t\tHi => LUAlarms[i].DCCurrent.Hi,\n\t\t\tHiHi => LUAlarms[i].DCCurrent.HiHi);\n\t\n\t\t//Temperature Alarm\n\t\tLUTempAlarm[i](En := NOT LUFbk[i].AlmComm,\n\t\t\tCfg_LoLoTime := LUAlarmCfg[i].ThreshTime, \n\t\t\tCfg_LoTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_LoLoLmt := LUAlarmCfg[i].ContTempFbk.LoLo,\n\t\t\tCfg_LoLmt := LUAlarmCfg[i].ContTempFbk.Lo,\n\t\t\tCfg_HiLmt := LUAlarmCfg[i].ContTempFbk.Hi,\n\t\t\tCfg_HiHiLmt := LUAlarmCfg[i].ContTempFbk.HiHi,\n\t\t\tIn := LUFbk[i].ContTemp,\n\t\t\tLoLo => LUAlarms[i].ContTemp.LoLo,\n\t\t\tLo => LUAlarms[i].ContTemp.Lo,\n\t\t\tHi => LUAlarms[i].ContTemp.Hi,\n\t\t\tHiHi => LUAlarms[i].ContTemp.HiHi);\n\t\t\t\n\t\t//SoC Alarm\n\t\tLUSoCAlarm[i](En := NOT LUFbk[i].AlmComm,\n\t\t\tCfg_LoLoTime := LUAlarmCfg[i].ThreshTime, \n\t\t\tCfg_LoTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_LoLoLmt := LUAlarmCfg[i].SoCFbk.LoLo,\n\t\t\tCfg_LoLmt := LUAlarmCfg[i].SoCFbk.Lo,\n\t\t\tCfg_HiLmt := LUAlarmCfg[i].SoCFbk.Hi,\n\t\t\tCfg_HiHiLmt := LUAlarmCfg[i].SoCFbk.HiHi,\n\t\t\tIn := LUFbk[i].AvgSoC,\n\t\t\tLoLo => LUAlarms[i].SoC.LoLo,\n\t\t\tLo => LUAlarms[i].SoC.Lo,\n\t\t\tHi => LUAlarms[i].SoC.Hi,\n\t\t\tHiHi => LUAlarms[i].SoC.HiHi);\t\n\t\t\t\n\t\t//AC Voltage Alarm\n\t\tLUACVAlarm[i](En := NOT LUFbk[i].AlmComm,\n\t\t\tCfg_LoLoTime := LUAlarmCfg[i].ThreshTime, \n\t\t\tCfg_LoTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_LoLoLmt := LUAlarmCfg[i].ACVoltageFbk.LoLo,\n\t\t\tCfg_LoLmt := LUAlarmCfg[i].ACVoltageFbk.Lo,\n\t\t\tCfg_HiLmt := LUAlarmCfg[i].ACVoltageFbk.Hi,\n\t\t\tCfg_HiHiLmt := LUAlarmCfg[i].ACVoltageFbk.HiHi,\n\t\t\tIn := LUFbk[i].InvACV,\n\t\t\tLoLo => LUAlarms[i].ACVoltage.LoLo,\n\t\t\tLo => LUAlarms[i].ACVoltage.Lo,\n\t\t\tHi => LUAlarms[i].ACVoltage.Hi,\n\t\t\tHiHi => LUAlarms[i].ACVoltage.HiHi);\t\n\t\t\n\t\t//AC Current Alarm\n\t\tLUACAAlarm[i](En := NOT LUFbk[i].AlmComm,\n\t\t\tCfg_LoLoTime := LUAlarmCfg[i].ThreshTime, \n\t\t\tCfg_LoTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_LoLoLmt := LUAlarmCfg[i].ACCurrentFbk.LoLo,\n\t\t\tCfg_LoLmt := LUAlarmCfg[i].ACCurrentFbk.Lo,\n\t\t\tCfg_HiLmt := LUAlarmCfg[i].ACCurrentFbk.Hi,\n\t\t\tCfg_HiHiLmt := LUAlarmCfg[i].ACCurrentFbk.HiHi,\n\t\t\tIn := LUFbk[i].InvACA,\n\t\t\tLoLo => LUAlarms[i].ACCurrent.LoLo,\n\t\t\tLo => LUAlarms[i].ACCurrent.Lo,\n\t\t\tHi => LUAlarms[i].ACCurrent.Hi,\n\t\t\tHiHi => LUAlarms[i].ACCurrent.HiHi);\t\n\t\t\t\n\t\t//SOH Alarm\n\t\tLUSOHAlarm[i](En := NOT LUFbk[i].AlmComm,\n\t\t\tCfg_LoLoTime := LUAlarmCfg[i].ThreshTime, \n\t\t\tCfg_LoTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_LoLoLmt := LUAlarmCfg[i].SOHFbk.LoLo,\n\t\t\tCfg_LoLmt := LUAlarmCfg[i].SOHFbk.Lo,\n\t\t\tIn := LUFbk[i].AvgSoH,\n\t\t\tLoLo => LUAlarms[i].SOH.LoLo,\n\t\t\tLo => LUAlarms[i].SOH.Lo);\n\t\t\t\n\t\t//Humidity Alarm\n\t\tLUHumidAlarm[i](En := NOT LUFbk[i].AlmComm,\n\t\t\tCfg_LoLoTime := LUAlarmCfg[i].ThreshTime, \n\t\t\tCfg_LoTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiTime := LUAlarmCfg[i].ThreshTime,\n\t\t\tCfg_HiHiLmt := LUAlarmCfg[i].ContHumidFbk.HiHi,\n\t\t\tCfg_HiLmt := LUAlarmCfg[i].ContHumidFbk.Hi,\n\t\t\tCfg_LoLoLmt := LUAlarmCfg[i].ContHumidFbk.LoLo,\n\t\t\tCfg_LoLmt := LUAlarmCfg[i].ContHumidFbk.Lo,\n\t\t\tIn := LUFbk[i].ContHumid,\n\t\t\tHiHi => LUAlarms[i].ContHumid.HiHi,\n\t\t\tHi => LUAlarms[i].ContHumid.Hi,\n\t\t\tLoLo => LUAlarms[i].ContHumid.LoLo,\n\t\t\tLo => LUAlarms[i].ContHumid.Lo);\n\t\t\t\n\t\t//Determine Alarm Level (Critical, Alarm, Warning or Normal)\n\t\tIF LUAlarms[i].FireSuppAlarm OR LUAlarms[i].HVACAlarm OR LUAlarms[i].Offline OR\n\t\t\tLUAlarms[i].ACVoltage.LoLo OR LUAlarms[i].ACVoltage.HiHi OR\n\t\t\tLUAlarms[i].ACCurrent.LoLo OR LUAlarms[i].ACCurrent.HiHi THEN\n\t\t\t\tLUAlarms[i].AlarmLevel := enum_AlarmLevel.Critical;\n\t\tELSIF LUAlarms[i].ContTemp.HiHi OR LUAlarms[i].DCVoltage.LoLo OR LUAlarms[i].DCVoltage.HiHi OR\n\t\t\t  LUAlarms[i].DCCurrent.LoLo OR LUAlarms[i].DCCurrent.HiHi OR\n\t\t      LUAlarms[i].SoC.LoLo OR LUAlarms[i].SoC.HiHi OR LUAlarms[i].ContTemp.LoLo   THEN\n\t\t\t  LUAlarms[i].AlarmLevel := enum_AlarmLevel.Alarm;\n\t\tELSIF LUAlarms[i].SoH.Lo OR LUAlarms[i].ContHumid.Hi OR\n\t\t\t  LUAlarms[i].ContDoorOpen OR LUAlarms[i].AuxSysFault OR\n\t\t\t  LUAlarms[i].SoC.Lo OR LUAlarms[i].SoC.Hi OR  LUAlarms[i].ContTemp.Hi OR\n\t\t\t  LUAlarms[i].ContHumid.HiHi  OR LUAlarms[i].ContHumid.Hi OR\n\t\t\t  LUAlarms[i].ContHumid.Lo OR LUAlarms[i].ContHumid.LoLo OR\n\t\t\t  LUAlarms[i].SoH.LoLo OR LUAlarms[i].ContTemp.Lo OR\n\t\t      LUAlarms[i].DCCurrent.Lo OR LUAlarms[i].DCCurrent.Hi OR\n\t\t      LUAlarms[i].DCVoltage.Lo OR LUAlarms[i].DCVoltage.Hi   THEN\n\t\t\t\tLUAlarms[i].AlarmLevel := enum_AlarmLevel.Warning;\n\t\tELSE\n\t\t\t\tLUAlarms[i].AlarmLevel := enum_AlarmLevel.Normal;\n\t\tEND_IF\n\tEND_IF\nEND_FOR\n\n//Determine plant-level alarms\n\n//Determine PPC Communication Alarm\nPlantAlarms.PPCCommFault := NOT PPC_GVL.CommOK;\n\n//Determine SCADA Communication Alarm\nPlantAlarms.SCADACommFault := NOT SCADA_GVL.CommOK;\n\n//Determine Meter Communication Alarm\nPlantAlarms.MeterCommFault := NOT Meter_GVL.CommOK;\n\n//Determine All LUs offline alarm\nPlantAlarms.AllLUsOffline := LUOfflineCount = SiteConstants.NumLineups;\n\n//Determine 50% LUs offline alarm\nPlantAlarms.HalfLUsOffline := LUOfflineCount >= 0.5 * SiteConstants.NumLineups;\n\n//Determine 80% LUs offline alarm\nPlantAlarms.MostLUsOffline := LUOfflineCount >= 0.8 * SiteConstants.NumLineups;\n\n//Control Loops Alarms\nPlantAlarms.POpenLoop   := NOT EMSDiag.PSpCtrlOutputs.PClosedLoopCtrlEn;\nPlantAlarms.QOpenLoop   := NOT EMSDiag.QSpCtrlOuptuts.QClosedLoopCtrlEn;\n\n//Determine Average SoC alarm\nAvgSoCAlarm(En := NOT PlantAlarms.AllLUsOffline,\n\t\t\tCfg_LoLoTime := PlantAlarmCfg.ThreshTime, \n\t\t\tCfg_LoTime := PlantAlarmCfg.ThreshTime,\n\t\t\tCfg_HiTime := PlantAlarmCfg.ThreshTime,\n\t\t\tCfg_HiHiTime := PlantAlarmCfg.ThreshTime,\n\t\t\tCfg_LoLoLmt := PlantAlarmCfg.SoC.LoLo,\n\t\t\tCfg_LoLmt := PlantAlarmCfg.SoC.Lo,\n\t\t\tCfg_HiLmt := PlantAlarmCfg.SoC.Hi,\n\t\t\tCfg_HiHiLmt := PlantAlarmCfg.SoC.HiHi,\n\t\t\tIn := EMSVFbk.AvgSoC,\n\t\t\tLoLo => PlantAlarms.SoC.LoLo,\n\t\t\tLo => PlantAlarms.SoC.Lo,\n\t\t\tHi => PlantAlarms.SoC.Hi,\n\t\t\tHiHi => PlantAlarms.SoC.HiHi);\t\n\t\t\t\n//Determine Active Power Alarm\nPlantActivePower(En := NOT PlantAlarms.AllLUsOffline,\n\t\t\tCfg_LoLoTime := PlantAlarmCfg.ThreshTime, \n\t\t\tCfg_LoTime := PlantAlarmCfg.ThreshTime,\n\t\t\tCfg_HiTime := PlantAlarmCfg.ThreshTime,\n\t\t\tCfg_HiHiTime := PlantAlarmCfg.ThreshTime,\n\t\t\tCfg_LoLoLmt := PlantAlarmCfg.PFbk.LoLo,\n\t\t\tCfg_LoLmt := PlantAlarmCfg.PFbk.Lo,\n\t\t\tCfg_HiLmt := PlantAlarmCfg.PFbk.Hi,\n\t\t\tCfg_HiHiLmt := PlantAlarmCfg.PFbk.HiHi,\n\t\t\tIn := MeterFbk.P,\n\t\t\tLoLo => PlantAlarms.PFbk.LoLo,\n\t\t\tLo => PlantAlarms.PFbk.Lo,\n\t\t\tHi => PlantAlarms.PFbk.Hi,\n\t\t\tHiHi => PlantAlarms.PFbk.HiHi);\t\n\t\t\t\n//Determine Alarm Level (Critical, Alarm, Warning or Normal)\nIF PlantAlarms.AllLUsOffline OR PlantAlarms.EMSHardwareFault THEN\n\tPlantAlarms.AlarmLevel := enum_AlarmLevel.Critical;\nELSIF PlantAlarms.MostLUsOffline OR PlantAlarms.SOC.HiHi OR PlantAlarms.SOC.LoLo OR  \n\tPlantAlarms.PFbk.HiHi OR PlantAlarms.PFbk.LoLo THEN\n\t PlantAlarms.AlarmLevel := enum_AlarmLevel.Alarm;\nELSIF PlantAlarms.HalfLUsOffline OR PlantAlarms.SOC.Hi OR PlantAlarms.SOC.Lo OR\n\tPlantAlarms.PFbk.Hi OR PlantAlarms.PFbk.Lo OR\n\tNOT EMSDiag.PSpCtrlOutputs.PClosedLoopCtrlEn OR NOT EMSDiag.QSpCtrlOuptuts.QClosedLoopCtrlEn OR\n\tPlantAlarms.EMSSupplyVoltFault OR PlantAlarms.EMSCPUUsageHigh THEN\n\t PlantAlarms.AlarmLevel := enum_AlarmLevel.Warning;\nELSE\n\t PlantAlarms.AlarmLevel := enum_AlarmLevel.Normal;\nEND_IF\t\t\t\n","LineInfoPersistence":"(string)bb27f359-1ae6-4a20-980e-4bdb3a26fc21_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tAlarms Program\n|\tDetermine Plant and LU Level Alarms\n*)\nPROGRAM pg_Alarms\nVAR_INPUT\n\tLUFbk\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUFbk;\n\tPlantAlarmCfg\t: dt_PlantAlarmCfg;\n\tLUAlarmCfg\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUAlarmCfg;\n\tEMSVFbk\t\t\t: dt_EMSVFbk; \n\tMeterFbk\t\t: dt_MeterFbk;\n\tEMSDiag\t\t\t: dt_EMSDiagnostics;\nEND_VAR\nVAR_OUTPUT\n\tPlantAlarms\t\t: dt_EMSPlantAlarms; \n\tLUAlarms\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUAlarms; \nEND_VAR\nVAR\n\ti\t\t\t\t: UINT;\n\t\n\t//LU Alarm FBs\n\tLUDCVAlarm\t\t: ARRAY[0..SiteConstants.NumLineups] OF TBE_POUs.fb_Alarm;\t\t//Alarm function block for Lineup DC Voltage \n\tLUDCAAlarm\t\t: ARRAY[0..SiteConstants.NumLineups] OF TBE_POUs.fb_Alarm;\t\t//Alarm function block for Lineup DC Current\n\tLUTempAlarm\t\t: ARRAY[0..SiteConstants.NumLineups] OF TBE_POUs.fb_Alarm;\t\t//Alarm function block for Lineup Temperature \n\tLUHumidAlarm\t: ARRAY[0..SiteConstants.NumLineups] OF TBE_POUs.fb_Alarm;\t\t//Alarm function block for Lineup Humidity \n\tLUSOCAlarm\t\t: ARRAY[0..SiteConstants.NumLineups] OF TBE_POUs.fb_Alarm;\t\t//Alarm function block for Lineup SOC \n\tLUSOHAlarm\t\t: ARRAY[0..SiteConstants.NumLineups] OF TBE_POUs.fb_Alarm;\t\t//Alarm function block for Lineup SOH\n\tLUACVAlarm\t\t: ARRAY[0..SiteConstants.NumLineups] OF TBE_POUs.fb_Alarm;\t\t//Alarm function block for Lineup AC Voltage \n\tLUACAAlarm\t\t: ARRAY[0..SiteConstants.NumLineups] OF TBE_POUs.fb_Alarm;\t\t//Alarm function block for Lineup AC Current\n\t\n\t//Plant Alarm FBs\n\tAvgSoCAlarm\t\t : TBE_POUs.fb_Alarm;\t\n\tPlantActivePower : \tTBE_POUs.fb_Alarm;\nEND_VAR\nVAR_TEMP\n\tLUOfflineCount\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Count of lineups that are offline/not communicating\nEND_VAR\n","LineInfoPersistence":"(string)bb27f359-1ae6-4a20-980e-4bdb3a26fc21_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)410","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}