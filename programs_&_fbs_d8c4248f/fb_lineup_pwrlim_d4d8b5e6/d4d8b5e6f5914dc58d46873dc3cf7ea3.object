{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)d4d8b5e6-f591-4dc5-8d46-873dc3cf7ea3","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_LineUp_PwrLim","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//SOC Balancing Logic\nIF SOC_Bal_En THEN\n\tSoCBal(Plant_Avg_SoC := PlantSoC,\n\t\t\tPCmd_In \t := Psp_Auto,\t\t\t\t\t\t\t\t\t\t\t\n\t\t\tLU_Avg_SoC \t := LUSoC,\n\t\t\tSoC_Db \t\t := SoCDb);\n\tPsp_Auto := SoCBal.PCmd_Out;\nEND_IF\n// --- Auto/Manual selection: Active ---\nIF PAuto THEN\n    Psp_In     := Psp_Auto;\nELSE\n    Psp_In     := Psp_Man;\nEND_IF;\n\n// --- Auto/Manual selection: Reactive ---\nIF QAuto THEN\n    Qsp_In     := Qsp_Auto;          \nELSE\n    Qsp_In     := Qsp_Man;    \nEND_IF;\n\n//Bumpless transfer between Auto/ manual\n\n// --- Magnitude check ---\nMagnitudeOK := (Smax >= 0.0) AND (SQRT(Psp_In*Psp_In + Qsp_In*Qsp_In) <= Smax);\n\n(*\n// Quality check for Set point tags\n// Active Power Setpoint\nIF NOT Psp_In.quality = good THEN\n\tPspReceived := FALSE; \nEND_IF\n// Reactive Power Setpoint\nIF NOT Qsp_In.quality = good THEN\n\tQspReceived := FALSE;\nEND_IF\n*)\n\nPspReceived := TRUE; \nQspReceived := TRUE;\n\n// --- Process setpoints with priority & projection ---\nIF NOT PspReceived THEN\n    ValidPsp := 0.0;\n    PspReady := FALSE;\nELSIF MagnitudeOK OR PspPri THEN\n\t//passing the active power setpoint if valid and the Magnitude check pass or active power priority\n    ValidPsp := Psp_In;\n    PspReady := TRUE;\nELSE\n    ValidPsp := PLim;\n    PspReady := TRUE;   // consistent\nEND_IF;\n\nIF NOT QspReceived THEN\n    ValidQsp := 0.0;\n    QspReady := FALSE;\nELSIF MagnitudeOK OR NOT PspPri THEN\n\t//passing the reactive power setpoint if valid and the Magnitude check pass or no active power priority\n    ValidQsp := Qsp_In;\n    QspReady := TRUE;\nELSE\n    ValidQsp := QLim;\n    QspReady := TRUE;   // consistent\nEND_IF;\n\n// Apply Smax with priority (vector projection)\nPQLimit(Pin := ValidPsp, Qin := ValidQsp, Smax := Smax, PPriority := PspPri);\n\nValidPsp := PQLimit.Pout;\nValidQsp := PQLimit.Qout;\n\n// Outputs\nPsp_Out := ValidPsp;\nQsp_Out := ValidQsp;","LineInfoPersistence":"(string)d4d8b5e6-f591-4dc5-8d46-873dc3cf7ea3_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_LineUp_PwrLim\nVAR_INPUT\n\tPAuto\t\t: BOOL;\t // TRUE: Active power setpoint from EMS - FALSE: Active power setpoint from SCADA/ HMI\n\tQAuto\t\t: BOOL;\t // TRUE: Rective power setpoint from EMS - FALSE: Reactive power setpoint from SCADA/ HMI\n\tPsp_Auto  \t: REAL;  // Active power setpoint from EMS (p.u.)\n    Qsp_Auto   \t: REAL;  // Reactive power setpoint from EMS(p.u.)\n\tPsp_Man    \t: REAL;  // Active power setpoint from EMS (p.u.)\n    Qsp_Man    \t: REAL;  // Reactive power setpoint from EMS(p.u.)\n\tSmax        : REAL;  // Apparent power limit (p.u.)\n\tPspPri\t\t: BOOL; // TRUE: Active Power Setpoint priority; FALSE: Reacitve Power Setpoint priority\n\tPLim\t\t: REAL; // Active Power Limit Setpoints in p.u\n\tQLim\t\t: REAL; // Reactive Power Limit Setpoints in p.u\n\tSoC_Bal_En\t: BOOL;\n\tPlantSoC\t: REAL;\n\tLUSoC\t\t: REAL;\n\tSoCDb\t\t: REAL;\n\tLoSoC\t\t: REAL;\n\tHiSoC\t\t: REAL;\nEND_VAR\nVAR_OUTPUT\n\tPsp_Out      \t: REAL;  // Active power setpoint (p.u.)\n    Qsp_Out      \t: REAL;  // Reactive power setpoint (p.u.)\nEND_VAR\nVAR\n\tPsp_In      \t: REAL;  // Active power setpoint (p.u.)\n    Qsp_In      \t: REAL;  // Reactive power setpoint (p.u.)\n\tPspReceived\t\t: BOOL; //Active power setpoints receviced\n\tQspReceived\t\t: BOOL; //Reactive power setpoints receviced\n\tValidPsp    \t: REAL;\t//Valid active power setpoint\n    ValidQsp    \t: REAL; //Valid reactive power setpoint\n    MagnitudeOK \t: BOOL; //Valid power setpoints condition\n    EnableControl \t: BOOL; //Checking for the Unit Condition\n\tPspReady    \t: BOOL;\t//Active power setpoint ready for the logic\n    QspReady    \t: BOOL; //Reactive power setpoint ready for the logic\n\tPQLimit\t\t\t: fb_PQLim;\n\tSoCBal\t\t\t: fb_SoCBal;\nEND_VAR\n","LineInfoPersistence":"(string)d4d8b5e6-f591-4dc5-8d46-873dc3cf7ea3_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)212","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}