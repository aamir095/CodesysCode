{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)da23e909-e6ec-4fa3-8a45-d2dcd3ff7f1a","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_LineUp_OpCtl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// Latch fault when trip is active\nIF Trip THEN\n    FaultLatch := TRUE;\nEND_IF;\n\n// Allow reset\nResetEdge(CLK := ManualReset);\n\nIF ResetEdge.Q OR (EnableAutoReset AND NOT Trip) THEN\n    FaultLatch := FALSE;\nEND_IF;\n\n// Determine if PCS can be enabled\nIF CmdEnable AND PermissiveOK AND NOT FaultLatch THEN\n    LineUp_EnableCmd := TRUE;\nELSE\n    LineUp_EnableCmd := FALSE;\nEND_IF\n\n// Status output\nLineUp_StatusOK := LineUp_EnableCmd AND OnlineFbk;\nLineUp_LockedOut := FaultLatch;","LineInfoPersistence":"(string)da23e909-e6ec-4fa3-8a45-d2dcd3ff7f1a_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_LineUp_OpCtl\nVAR_INPUT\n\tCmdEnable       : BOOL;       // Enable command from EMS/operator\n    PermissiveOK    : BOOL;       // Output from PCS Permissive logic\n    Trip            : BOOL;       // TRUE = PCS fault/trip active\n    OnlineFbk       : BOOL;       // TRUE = PCS is online (feedback)\n    ManualReset     : BOOL := FALSE; // Optional manual reset input\n    EnableAutoReset : BOOL := TRUE;  // Auto restart when Trip clears\nEND_VAR\nVAR_OUTPUT\n\tLineUp_EnableCmd   : BOOL;       // Output command to PCS: Enable\n    LineUp_StatusOK    : BOOL;       // Status: Ready and Online\n    LineUp_LockedOut   : BOOL;       // Requires manual reset or waiting for clear\nEND_VAR\nVAR\n\tFaultLatch      : BOOL;\n    ResetEdge       : R_TRIG;     // Edge detection for manual reset\nEND_VAR\n","LineInfoPersistence":"(string)da23e909-e6ec-4fa3-8a45-d2dcd3ff7f1a_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)59","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}