{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)98ab9304-7149-4d80-a25b-196195147c9b","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_QSpCtrl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine open vs. closed loop control\nQSpCtrlOutputs.QClosedLoopCtrlEn := EMSOPSts.QClosedLoopCtrlPerm AND HMIInputs.ClosedLoopCtrlEn;\n\n\n(*\n//Power Factor Limit\nIF HMIInputs.Pf > ReactivePwrCfg.PfMax THEN\n\tHMIInputs.Pf := ReactivePwrCfg.PfMax;\n\tQSpCtrlOutputs.LimPF := TRUE;\nELSIF HMIInputs.Pf < ReactivePwrCfg.PfMin THEN\n\tHMIInputs.Pf := ReactivePwrCfg.PfMax;\n\tQSpCtrlOutputs.LimPF := TRUE;\nELSE\n\tQSpCtrlOutputs.LimPF := FALSE;\nEND_IF\n*)\n\n\n\n//Selecting Reactive Power Control Mode\nIF HMIInputs.PFCtlMode AND QSpCtrlOutputs.QClosedLoopCtrlEn AND HMIInputs.Pf <> 0 THEN\n\tQSpCtrlOutputs.PFCtlMode := TRUE;\nELSE\n\tQSpCtrlOutputs.PFCtlMode := FALSE;\nEND_IF\n\nIF QSpCtrlOutputs.PFCtlMode AND QSpCtrlOutputs.QClosedLoopCtrlEn AND HMIInputs.Pf <> 0 THEN\n\t//Determine active power setpoint based on operating mode\n\tQSpCtrlOutputs.QSp_PreRamp := MeterFbk.P * TAN(ACOS(HMIInputs.Pf));\nELSE\n\tIF EMSOpSts.QOpState = enum_EMSOpState.PPC THEN\n\t\t//Use reactive power setpoint from PPC\n\t\tIF PPCInputs.Qsp > 0 THEN\n\t\t//Positive reactive power setpoint \n\t\tQSpCtrlOutputs.QSp_PreRamp := MIN(PPCInputs.Qsp,EMSVFbk.NomRePwrCap);\n\t\t\tIF QSpCtrlOutputs.QSp_PreRamp < PPCInputs.Qsp THEN\n\t\t\t\tQSpCtrlOutputs.LimSP := TRUE;\n\t\t\tELSE\n\t\t\t\tQSpCtrlOutputs.LimSP := FALSE;\n\t\t\tEND_IF\n\t\tELSIF PPCInputs.Qsp < 0 THEN\n\t\t//Negative reactive power setpoint \n\t\tQSpCtrlOutputs.QSp_PreRamp := MAX(PPCInputs.Qsp,(-1)*EMSVFbk.NomRePwrCap);\n\t\t\tIF QSpCtrlOutputs.QSp_PreRamp > PPCInputs.Qsp THEN\n\t\t\t\tQSpCtrlOutputs.LimSP := TRUE;\n\t\t\tELSE\n\t\t\t\tQSpCtrlOutputs.LimSP := FALSE;\n\t\t\tEND_IF\n\t\tELSE\n\t\t\tQSpCtrlOutputs.QSp_PreRamp := 0;\n\t\t\tQSpCtrlOutputs.LimSP \t   := FALSE;\n\t\tEND_IF\n\tELSIF EMSOpSts.QOpState = enum_EMSOpState.SCADA THEN\n\t\t//Use active power setpoint from SCADA\n\t\tIF HMIInputs.Qsp > 0 THEN\n\t\t//Positive reactive power setpoint \n\t\tQSpCtrlOutputs.QSp_PreRamp := MIN(HMIInputs.Qsp, EMSVFbk.NomRePwrCap);\n\t\t\tIF QSpCtrlOutputs.QSp_PreRamp < HMIInputs.Qsp THEN\n\t\t\t\tQSpCtrlOutputs.LimSP := TRUE;\n\t\t\tELSE\n\t\t\t\tQSpCtrlOutputs.LimSP := FALSE;\n\t\t\tEND_IF\n\t\tELSIF HMIInputs.Qsp < 0 THEN\n\t\t//Negative reactive power setpoint \n\t\tQSpCtrlOutputs.QSp_PreRamp := MAX(HMIInputs.Qsp,(-1)*EMSVFbk.NomRePwrCap);\n\t\t\tIF QSpCtrlOutputs.QSp_PreRamp > HMIInputs.Qsp THEN\n\t\t\t\tQSpCtrlOutputs.LimSP := TRUE;\n\t\t\tELSE\n\t\t\t\tQSpCtrlOutputs.LimSP := FALSE;\n\t\t\tEND_IF\n\t\tELSE\n\t\t\tQSpCtrlOutputs.QSp_PreRamp := 0;\n\t\t\tQSpCtrlOutputs.LimSP \t   := FALSE;\n\t\tEND_IF\n\tELSE\n\t\t//Operating state is STOP or Fault - set setpoint to 0\n\t\tQSpCtrlOutputs.QSp_PreRamp := 0; \n\t\tQSpCtrlOutputs.LimSP \t   := FALSE;\n\tEND_IF\nEND_IF\n\n//Apply ramp rate to setpoint\nRampBlock(En := TRUE, Auto := QSpCtrlOutputs.QClosedLoopCtrlEn, FreezeUp := FALSE, FreezeDn := FALSE, SP := QSpCtrlOutputs.QSp_PreRamp, PV := MeterFbk.Q, UpLim := ReactivePwrCfg.QUpLim, DnLim := ReactivePwrCfg.QDnLim, TaskTime := TaskTime, Out => QSpCtrlOutputs.QSp_PostRamp); \n\n//Apply limit to setpoint\nQSpCtrlOutputs.QSp_PostLim := LIMIT(ReactivePwrCfg.QSpMin, QSpCtrlOutputs.QSp_PostRamp, ReactivePwrCfg.QSpMax); ","LineInfoPersistence":"(string)98ab9304-7149-4d80-a25b-196195147c9b_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tReactive Power Setpoint Control\n|\tDetermine plant-level reactive power setpoint and closed/open loop control for reactive power closed loop control program\n*)\nPROGRAM pg_QSpCtrl\nVAR_INPUT\n\tEMSOpSts\t\t: dt_EMSOpSts;\n\tHMIInputs\t\t: dt_ReactivePwrHMIInputs;\n\tPPCInputs\t\t: dt_PPCInputs; \n\tReactivePwrCfg\t: dt_ReactivePwrCfg;\n\tMeterFbk\t\t: dt_MeterFbk; \n\tEMSVFbk\t\t\t: dt_EMSVFbk; \n\tTaskTime\t\t: UINT;\nEND_VAR\nVAR_OUTPUT\n\tQSpCtrlOutputs\t\t: dt_QSpCtrlOutputs; \nEND_VAR\nVAR\n\tRampBlock\t\t\t: TBE_POUs.fb_R_LIM;\t\t//Ramp rate block\nEND_VAR\n","LineInfoPersistence":"(string)98ab9304-7149-4d80-a25b-196195147c9b_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)238","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}