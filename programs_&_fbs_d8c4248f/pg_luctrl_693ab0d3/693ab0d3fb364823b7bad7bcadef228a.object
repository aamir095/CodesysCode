{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)693ab0d3-fb36-4823-b7ba-d7bcadef228a","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_LUCtrl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)d8c4248f-b019-448c-9df8-e754b62488e3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//SOC Balancing\n\n//Determine if SOC Balancing is enabled\nPlantSoCBalPerm := ActivePwrHMIInputs.SoCBalEn AND EMSVFbk.LUAvailPct > 80.0; \n\n//Loop through all Lineups and apply SoC balancing logic\nFOR i := 0 TO SiteConstants.NumLineups BY 1 DO\n\tIF i > 0 THEN\n\t\tIF i > 0 THEN\n\t\t\t//Determine if each LU is within the balancing pool and then call balancing FB\n\t\t\tLUBalPerm[i] := LUCtrlSts[i].POpState = enum_LUOpState.Auto; \n\t\t\tLUSoCBalFBs[i](SoCBalEn := PlantSoCBalPerm AND LUBalPerm[i], Plant_Avg_SoC := EMSVFbk.AvgSoC, LU_Avg_SoC := LUFbk[i].AvgSoC, SoC_DB := EMSCfg.SoCBalCfg.SoCDb, SoC_Gain := EMSCfg.SoCBalCfg.BalGain, PCmd_In := PspPlant, PCmd_Out => PSp_PostBal[i]); \n\t\tEND_IF\n\tEND_IF\nEND_FOR\n\nFOR i := 0 TO SiteConstants.NumLineups BY 1 DO\n\tPnomLU[i] := LUCfg[i].PNom; \nEND_FOR\n//Scaling the Active Power command if the average is diffferent\nLUPScaleFBs (PspPlant := PspPlant, PnomPlant := EMSVFbk.NomPwrCap , PspLU_In := PSp_PostBal, PnomLU := PnomLU, Tolerance := EMSCfg.SoCBalCfg.PlantTol, PspLU_Out => PSp_PostBal);\n//Loop through all Lineups and call LU Control FB for each one\nFOR i := 0 TO SiteConstants.NumLineups BY 1 DO\n\tIF i > 0 THEN\n\t\t//LUCtrlFBs[i](LUHMIInputs := LUHMIInputs[i], PSpPlant := PSpPlant, QSpPlant := QSpPlant, LUAlarms := LUAlarms[i], EMSOpSts := EMSOpSts, LUCfg := LUCfg[i], LUFbk := LUFbk[i], PPriority := EMSCfg.PPriority, TaskTime := Cfg_GVL.TaskTime, LUCtrlSts => LUCtrlSts[i], LUCmds => LUCmds[i]); \n\t\tLUCtrlFBs[i](LUHMIInputs := LUHMIInputs[i], PSpPlant := PSp_PostBal[i], QSpPlant := QSpPlant, LUAlarms := LUAlarms[i], EMSOpSts := EMSOpSts, LUCfg := LUCfg[i], LUFbk := LUFbk[i], PPriority := EMSCfg.PPriority, TaskTime := Cfg_GVL.TaskTime, LUCtrlSts => LUCtrlSts[i], LUCmds => LUCmds[i]); \n\t\t\n\t\t//Map in Balancing Status/Diagnostic tags\n\t\tLUCtrlSts[i].PSp_PreBal := PSpPlant;\n\t\tLUCtrlSts[i].PSp_PostBal := PSp_PostBal[i];\n\t\tLUCtrlSts[i].PSp_PostAdj := 0; \n\t\tLUCtrlSts[i].BalSts\t:= LUSocBalFBs[i].BalSts; \n\tEND_IF\nEND_FOR\n\n\n ","LineInfoPersistence":"(string)693ab0d3-fb36-4823-b7ba-d7bcadef228a_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tLineup Control Program\n*)\nPROGRAM pg_LUCtrl\nVAR_INPUT\n\tPSpPlant\t\t\t: REAL;\n\tQSpPlant\t\t\t: REAL; \n\tEMSOpSts\t\t\t: dt_EMSOpSts;\n\tLUAlarms\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUAlarms; \n\tLUHMIInputs\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUHMIInputs;\n\tActivePwrHMIInputs\t: dt_ActivePwrHMIInputs; \n\tLUFbk\t\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUFbk;\n\tEMSVFbk\t\t\t\t: dt_EMSVFbk;\n\tEMSCfg\t\t\t\t: dt_EMSCfg;\n\tLUCfg\t\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUCfg;\nEND_VAR\nVAR_OUTPUT\n\tLUCtrlSts\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUCtrlSts;\n\tLUCmds\t\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUCmds;\nEND_VAR\nVAR\n\ti\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Indexing variable\n\tLUCtrlFBs\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF fb_LUCtrl; \t\t\t//Array of Lineup control function blocks (1 per lineup)\n\tLUSoCBalFBs\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF fb_SoCBal;\t\t\t//Array of SoC balancing function blocks (1 per lineup)\n\tPSp_PostBal\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF REAL;\t\t\t\t//LU Active Power Setpoint post-balancing logic\n\tPnomLU\t\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF REAL;\t\t\t\t//LU Active Power Setpoint post-balancing logic\n\tLUBalPerm\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF BOOL;\t\t\t\t//[True = LU balancing is permitted, False = LU balancing is prohibited]\n\tPlantSoCBalPerm\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//[True = Plant SoC Balancing Enabled, False = Plant SoC balancing disabled]\n\tLUPScaleFBs\t\t\t: fb_SoCScale;\nEND_VAR\n","LineInfoPersistence":"(string)693ab0d3-fb36-4823-b7ba-d7bcadef228a_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)223","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}