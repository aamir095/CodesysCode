{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)126b42c8-8227-4722-bb00-6e9fedfe000a","ParentGuid":"(Guid)41ef8a33-9bca-4c77-bb31-871febc5a812","Name":"(string)meth_SetDefaultPlantCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Plant Level Configuration\nCfg_GVL.EMSCfg_eng.Snom := 6; \t\t\t\t\t\t\t\t\t\t\t//[MVA]\nCfg_GVL.EMSCfg_eng.Pnom := 6;\t\t\t\t\t\t\t\t\t\t\t//[MW]\nCfg_GVL.EMSCfg_eng.Qnom := 6;\t\t\t\t\t\t\t\t\t\t\t//[MVAr]\nCfg_GVL.EMSCfg_eng.PPriority := FALSE;\t\t\t\t\t\t\t\t\t//[True = PPriority, False = QPriority]\nCfg_GVL.TaskTime := 20;\t\t\t\t\t\t\t\t\t\t\t\t\t//[ms]\n\n//SoC Configuration\nCfg_GVL.EMSCfg_eng.SoCBalCfg.BalGain := 0.5;\t\t\t\t\t\t\t//SOC Balancing Gain\nCfg_GVL.EMSCfg_eng.SoCBalCfg.PlantTol := 0.05;\t\t\t\t\t\t\t\t//[MW]\nCfg_GVL.EMSCfg_eng.SoCBalCfg.SoCDb := 2;\t\t\t\t\t\t\t\t//[%]\n\n//Active Power\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.PSpMax := 6;\t\t\t\t\t\t\t//[MW]\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.PSpMin := -6;\t\t\t\t\t\t\t//[MW]\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.PUpLim := 5;\t\t\t\t\t\t\t//[MW/min]\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.PDnLim := 5;\t\t\t\t\t\t\t//[MW/min]\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.OvershootPreventionEnabled := FALSE;\t//Overshoot prevention enable/disable\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.OvershootDbd1 := 2;\t\t\t\t\t\t//[%]\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.OvershootDbd2 := 3;\t\t\t\t\t\t//[%]\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.OvershootResp := 0;\t\t\t\t\t\t//[pu/cycle]\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.PIDTuning.Kp := 0.1;\t\t\t\t\t//PI Proportional Gain\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.PIDTuning.Ki := 0.2;\t\t\t\t\t//PI Integral Gain\nCfg_GVL.EMSCfg_eng.ActivePwrCfg.PIDTuning.ITrackEn := TRUE;\t\t\t\t//Integral Tracking Enable/Disable\n\n//Reactive Power\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.QSpMax := 6;\t\t\t\t\t\t\t//[MVAr]\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.QSpMin := -6;\t\t\t\t\t\t\t//[MVAr]\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.QUpLim := 5;\t\t\t\t\t\t\t//[MVAr/min]\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.QDnLim := 5;\t\t\t\t\t\t\t//[MVAr/min]\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.PfMax := 0.95;\t\t\t\t\t\t//Pf\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.PfMin := -0.95;\t\t\t\t\t\t//Pf\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.OvershootPreventionEnabled := FALSE;\t//Overshoot prevention enable/disable\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.OvershootDbd1 := 2;\t\t\t\t\t\t//[%]\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.OvershootDbd2 := 3;\t\t\t\t\t\t//[%]\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.OvershootResp := 0;\t\t\t\t\t\t//[pu/cycle]\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.PIDTuning.Kp := 0.1;\t\t\t\t\t//PI Proportional Gain\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.PIDTuning.Ki := 0.2;\t\t\t\t\t//PI Integral Gain\nCfg_GVL.EMSCfg_eng.ReactivePwrCfg.PIDTuning.ITrackEn := TRUE;\t\t\t\t//Integral Tracking Enable/Disable\n\n//Alarm Thresholds\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.PFbk.LoLo := -Cfg_GVL.EMSCfg_eng.Snom;\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.PFbk.Lo := -Cfg_GVL.EMSCfg_eng.Snom;\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.PFbk.Hi := Cfg_GVL.EMSCfg_eng.Snom;\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.PFbk.HiHi := Cfg_GVL.EMSCfg_eng.Snom;\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.QFbk.LoLo := -Cfg_GVL.EMSCfg_eng.Qnom;\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.QFbk.Lo := -Cfg_GVL.EMSCfg_eng.Qnom;\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.QFbk.Hi := Cfg_GVL.EMSCfg_eng.Qnom;\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.QFbk.HiHi := Cfg_GVL.EMSCfg_eng.Qnom;\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.SOC.LoLo := 2;\t\t\t\t\t\t\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.SOC.Lo := 5;\t\t\t\t\t\t\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.SOC.Hi := 95;\t\t\t\t\t\t\t//[MW]\nCfg_GVL.EMSCfg_eng.PlantAlarmCfg.SOC.HiHi := 98;\t\t\t\t\t\t//[MW]","LineInfoPersistence":"(string)126b42c8-8227-4722-bb00-6e9fedfe000a_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tSet default plant configuration values\n|\tThis method will set the default values only - will only run when retained vars are reset (or if forced manually)\n|\tAll values within this program will be in engineering units (refer to comments)\n*)\nMETHOD meth_SetDefaultPlantCfg\nVAR_INPUT\nEND_VAR\n","LineInfoPersistence":"(string)126b42c8-8227-4722-bb00-6e9fedfe000a_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}