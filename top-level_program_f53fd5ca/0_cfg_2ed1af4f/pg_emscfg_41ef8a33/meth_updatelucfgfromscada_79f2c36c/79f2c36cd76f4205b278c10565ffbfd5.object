{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)79f2c36c-d76f-4205-b278-c10565ffbfd5","ParentGuid":"(Guid)41ef8a33-9bca-4c77-bb31-871febc5a812","Name":"(string)meth_UpdateLUCfgFromSCADA","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move over entire LUCfg Struct and then scale non-boolean values as necessary\nCfg_GVL.LUCfg_pu := Cfg_GVL.LUCfg_Eng;\nCfg_GVL.LUAlarmCfg_pu := Cfg_GVL.LUAlarmCfg_eng; \n\nFOR i := 0 TO SiteConstants.NumLineups BY 1 DO\n\t\tCfg_GVL.LUCfg_pu[i].PNom := Cfg_GVL.LUCfg_Eng[i].PNom / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUCfg_pu[i].QNom := Cfg_GVL.LUCfg_Eng[i].QNom / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUCfg_pu[i].SNom := Cfg_GVL.LUCfg_Eng[i].SNom / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t\t\t//Convert from kVA to pu\n\t\t\t\t\n\t\t\n\t\t//General LU Configuration\n\t\tCfg_GVL.LUCfg_pu[i].PRampUpRt := Cfg_GVL.LUCfg_Eng[i].PRampUpRt / Cfg_GVL.LUCfg_Eng[i].SNom ;\t\t//kW/s to pu/s\n\t\tCfg_GVL.LUCfg_pu[i].PRampDnRt := Cfg_GVL.LUCfg_Eng[i].PRampDnRt / Cfg_GVL.LUCfg_Eng[i].SNom ;\t\t//kW/s to pu/s\n\t\tCfg_GVL.LUCfg_pu[i].QRampUpRt := Cfg_GVL.LUCfg_Eng[i].QRampUpRt / Cfg_GVL.LUCfg_Eng[i].SNom ;\t\t//kW/s to pu/s\n\t\tCfg_GVL.LUCfg_pu[i].QRampDnRt := Cfg_GVL.LUCfg_Eng[i].QRampDnRt / Cfg_GVL.LUCfg_Eng[i].SNom ;\t\t//kW/s to pu/s\n\t\t\n\t\t//LU Alarm Configuration\n\t\t//Active Power Feedback Alarm\n\t\tCfg_GVL.LUAlarmCfg_pu[i].PFbk.LoLo := Cfg_GVL.LUAlarmCfg_eng[i].PFbk.LoLo / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].PFbk.Lo := Cfg_GVL.LUAlarmCfg_eng[i].PFbk.Lo / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].PFbk.Hi := Cfg_GVL.LUAlarmCfg_eng[i].PFbk.Hi / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].PFbk.HiHi := Cfg_GVL.LUAlarmCfg_eng[i].PFbk.HiHi / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t//Convert from kW to pu\n\t\t\n\t\t//Reactive Power Feedback Alarm\n\t\tCfg_GVL.LUAlarmCfg_pu[i].QFbk.LoLo := Cfg_GVL.LUAlarmCfg_eng[i].QFbk.LoLo / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].QFbk.Lo := Cfg_GVL.LUAlarmCfg_eng[i].QFbk.Lo / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].QFbk.Hi := Cfg_GVL.LUAlarmCfg_eng[i].QFbk.Hi / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].QFbk.HiHi := Cfg_GVL.LUAlarmCfg_eng[i].QFbk.HiHi / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t//Convert from kW to pu\n\t\t\n\t\t//State of Charge Feedback Alarm\n\t\tCfg_GVL.LUAlarmCfg_pu[i].SOCFbk.LoLo := Cfg_GVL.LUAlarmCfg_eng[i].SOCFbk.LoLo / 100.0;\t\t\t\t\t\t\t\t//Convert from % to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].SOCFbk.Lo := Cfg_GVL.LUAlarmCfg_eng[i].SOCFbk.Lo / 100.0;\t\t\t\t\t\t\t\t\t//Convert from % to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].SOCFbk.Hi := Cfg_GVL.LUAlarmCfg_eng[i].SOCFbk.Hi / 100.0;\t\t\t\t\t\t\t\t\t//Convert from % to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].SOCFbk.HiHi := Cfg_GVL.LUAlarmCfg_eng[i].SOCFbk.HiHi / 100.0;\t\t\t\t\t\t\t\t//Convert from % to pu\n\t\t\n\t\t//State of Health Feedback Alarm\n\t\tCfg_GVL.LUAlarmCfg_pu[i].SoHFbk.LoLo := Cfg_GVL.LUAlarmCfg_eng[i].SoHFbk.LoLo / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t//Convert from kW to pu\n\t\tCfg_GVL.LUAlarmCfg_pu[i].SoHFbk.Lo := Cfg_GVL.LUAlarmCfg_eng[i].SoHFbk.Lo / Cfg_GVL.LUCfg_Eng[i].SNom;\t\t\t//Convert from kW to pu\nEND_FOR","LineInfoPersistence":"(string)79f2c36c-d76f-4205-b278-c10565ffbfd5_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_UpdateLUCfgFromSCADA\nVAR_INPUT\nEND_VAR\nVAR\n\ti\t\t: UINT;\t\t//Unit Indexing variable\n\tj\t\t: UINT;\t\t//BESS per Unit Indexing variable\nEND_VAR\n","LineInfoPersistence":"(string)79f2c36c-d76f-4205-b278-c10565ffbfd5_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}