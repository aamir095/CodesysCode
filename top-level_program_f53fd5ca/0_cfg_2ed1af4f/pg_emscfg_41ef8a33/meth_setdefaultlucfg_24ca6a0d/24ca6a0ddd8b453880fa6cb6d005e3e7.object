{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)24ca6a0d-dd8b-4538-80fa-6cb6d005e3e7","ParentGuid":"(Guid)41ef8a33-9bca-4c77-bb31-871febc5a812","Name":"(string)meth_SetDefaultLUCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FOR i := 0 TO SiteConstants.NumLineups DO\n\tCfg_GVL.LUCfg_eng[i].PNom := 2000;\t\t\t\t//[kW]\n\tCfg_GVL.LUCfg_eng[i].SNom := 2000;\t\t\t\t//[kVA]\n\tCfg_GVL.LUCfg_eng[i].QNom := 2000;\t\t\t\t//[kVAr]\n\t\n\tCfg_GVL.LUCfg_Eng[i].PRampDnRt := 100;\t\t\t//[kW/S]\n\tCfg_GVL.LUCfg_Eng[i].PRampUpRt := 100;\t\t\t//[kW/S]\n\tCfg_GVL.LUCfg_Eng[i].QRampDnRt := 100;\t\t\t//[kVAr]\n\tCfg_GVL.LUCfg_Eng[i].QRampUpRt := 100;\t\t\t//[kVAr]\n\t\n\tCfg_GVL.LUCfg_Eng[i].Humid_SF := 1;\n\tCfg_GVL.LUCfg_Eng[i].InvA_SF := 1;\n\tCfg_GVL.LUCfg_Eng[i].InvACPwr_SF := 1/Cfg_GVL.LUCfg_eng[i].SNom;\n\tCfg_GVL.LUCfg_Eng[i].InvApPwr_SF := 1/Cfg_GVL.LUCfg_eng[i].SNom;\n\tCfg_GVL.LUCfg_Eng[i].InvDCA_SF := 1;\n\tCfg_GVL.LUCfg_Eng[i].InvDCPwr_SF := 1;\n\tCfg_GVL.LUCfg_Eng[i].InvDCV_SF := 1;\n\tCfg_GVL.LUCfg_Eng[i].InvRePwr_SF := 1/Cfg_GVL.LUCfg_eng[i].SNom;\n\tCfg_GVL.LUCfg_Eng[i].InvV_SF := 1;\n\tCfg_GVL.LUCfg_Eng[i].PwrChaCap_SF := 1/Cfg_GVL.LUCfg_eng[i].SNom;\n\tCfg_GVL.LUCfg_Eng[i].PwrDisChaCap_SF := 1/Cfg_GVL.LUCfg_eng[i].SNom;\n\tCfg_GVL.LUCfg_Eng[i].RePwrAbsCap_SF := 1/Cfg_GVL.LUCfg_eng[i].SNom;\n\tCfg_GVL.LUCfg_Eng[i].RePwrInjCap_SF := 1/Cfg_GVL.LUCfg_eng[i].SNom;\n\tCfg_GVL.LUCfg_Eng[i].SoC_SF := 0.01;\n\tCfg_GVL.LUCfg_Eng[i].SoH_SF := 0.01;\n\tCfg_GVL.LUCfg_Eng[i].Temp_SF := 1;\n\t\n\t//Alarm Configuration\n\tCfg_GVL.LUAlarmCfg_eng[i].ThreshTime := T#500MS; \n\tCfg_GVL.LUAlarmCfg_eng[i].PFbk.LoLo := -Cfg_GVL.LUCfg_eng[i].PNom;\t\t//[kW]\n\tCfg_GVL.LUAlarmCfg_eng[i].PFbk.Lo := -Cfg_GVL.LUCfg_eng[i].PNom;\t\t//[kW]\n\tCfg_GVL.LUAlarmCfg_eng[i].PFbk.Hi := Cfg_GVL.LUCfg_eng[i].PNom;\t\t\t//[kW]\n\tCfg_GVL.LUAlarmCfg_eng[i].PFbk.HiHi := Cfg_GVL.LUCfg_eng[i].PNom;\t\t//[kW]\n\tCfg_GVL.LUAlarmCfg_eng[i].QFbk.LoLo := -Cfg_GVL.LUCfg_eng[i].QNom;\t\t//[kVAr]\n\tCfg_GVL.LUAlarmCfg_eng[i].QFbk.Lo := -Cfg_GVL.LUCfg_eng[i].QNom;\t\t//[kVAr]\n\tCfg_GVL.LUAlarmCfg_eng[i].QFbk.Hi := Cfg_GVL.LUCfg_eng[i].QNom;\t\t\t//[kVAr]\n\tCfg_GVL.LUAlarmCfg_eng[i].QFbk.HiHi := Cfg_GVL.LUCfg_eng[i].QNom;\t\t//[kVAr]\n\tCfg_GVL.LUAlarmCfg_eng[i].SOCFbk.LoLo := 2;\t\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].SOCFbk.Lo := 5;\t\t\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].SOCFbk.Hi := 95;\t\t\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].SOCFbk.HiHi := 98;\t\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].SOHFbk.LoLo := -98;\t\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].SOHFbk.Lo := -95;\t\t\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].ACCurrentFbk.LoLo := -1000;\t\t\t\t\t//[A]\n\tCfg_GVL.LUAlarmCfg_eng[i].ACCurrentFbk.Lo := -1000;\t\t\t\t\t\t//[A]\n\tCfg_GVL.LUAlarmCfg_eng[i].ACCurrentFbk.Hi := 1000;\t\t\t\t\t\t//[A]\n\tCfg_GVL.LUAlarmCfg_eng[i].ACCurrentFbk.HiHi := 1000;\t\t\t\t\t//[A]\n\tCfg_GVL.LUAlarmCfg_eng[i].ACVoltageFbk.LoLo := -800;\t\t\t\t\t//[V]\n\tCfg_GVL.LUAlarmCfg_eng[i].ACVoltageFbk.Lo := -900;\t\t\t\t\t\t//[V]\n\tCfg_GVL.LUAlarmCfg_eng[i].ACVoltageFbk.Hi := 1600;\t\t\t\t\t\t//[V]\n\tCfg_GVL.LUAlarmCfg_eng[i].ACVoltageFbk.HiHi := 1800;\t\t\t\t\t//[V]\n\tCfg_GVL.LUAlarmCfg_eng[i].ContHumidFbk.LoLo := 1;\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].ContHumidFbk.Lo := 1;\t\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].ContHumidFbk.Hi := 95;\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].ContHumidFbk.HiHi := 98;\t\t\t\t\t\t//[%]\n\tCfg_GVL.LUAlarmCfg_eng[i].ContTempFbk.LoLo := -98;\t\t\t\t\t\t//[C]\n\tCfg_GVL.LUAlarmCfg_eng[i].ContTempFbk.Lo := -95;\t\t\t\t\t\t//[C]\n\tCfg_GVL.LUAlarmCfg_eng[i].ContTempFbk.Hi := 95;\t\t\t\t\t\t\t//[C]\n\tCfg_GVL.LUAlarmCfg_eng[i].ContTempFbk.HiHi := 98;\t\t\t\t\t\t//[C]\n\tCfg_GVL.LUAlarmCfg_eng[i].DCCurrentFbk.LoLo := -1000;\t\t\t\t\t//[A]\n\tCfg_GVL.LUAlarmCfg_eng[i].DCCurrentFbk.Lo := -1000;\t\t\t\t\t\t//[A]\n\tCfg_GVL.LUAlarmCfg_eng[i].DCCurrentFbk.Hi := 1000;\t\t\t\t\t\t//[A]\n\tCfg_GVL.LUAlarmCfg_eng[i].DCCurrentFbk.HiHi := 1000;\t\t\t\t\t//[A]\n\tCfg_GVL.LUAlarmCfg_eng[i].DCVoltageFbk.LoLo := 0;\t\t\t\t\t\t//[V]\n\tCfg_GVL.LUAlarmCfg_eng[i].DCVoltageFbk.Lo := 0;\t\t\t\t\t\t\t//[V]\n\tCfg_GVL.LUAlarmCfg_eng[i].DCVoltageFbk.Hi := 2000;\t\t\t\t\t\t//[V]\n\tCfg_GVL.LUAlarmCfg_eng[i].DCVoltageFbk.HiHi := 2000;\t\t\t\t\t//[V]\nEND_FOR\n","LineInfoPersistence":"(string)24ca6a0d-dd8b-4538-80fa-6cb6d005e3e7_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tSet default unit configuration values\n|\tThis method will set the default values only - will only run when retained vars are reset (or if forced manually)\n|\tAll values within this program will be in engineering units (refer to comments)\n*)\nMETHOD meth_SetDefaultLUCfg\nVAR_INPUT\nEND_VAR\nVAR\n\ti\t\t: UINT;\t\t//Unit Indexing variable\n\tj\t\t: UINT;\t\t//BESS per Unit Indexing variable\nEND_VAR","LineInfoPersistence":"(string)24ca6a0d-dd8b-4538-80fa-6cb6d005e3e7_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}