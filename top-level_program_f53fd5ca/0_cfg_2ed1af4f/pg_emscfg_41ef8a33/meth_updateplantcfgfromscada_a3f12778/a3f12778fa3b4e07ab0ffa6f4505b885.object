{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)a3f12778-fa3b-4e07-ab0f-fa6f4505b885","ParentGuid":"(Guid)41ef8a33-9bca-4c77-bb31-871febc5a812","Name":"(string)meth_UpdatePlantCfgFromSCADA","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move over entire PlantCfg structure and then scale non-boolean values as necessary\nCfg_GVL.EMSCfg_pu := Cfg_GVL.EMSCfg_eng;\n\n//Plant Level Active Power Config\nCfg_GVL.EMSCfg_pu.ActivePwrCfg.PSpMax := Cfg_GVL.EMSCfg_eng.ActivePwrCfg.PSpMax / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t\t//Convert from MW to pu\nCfg_GVL.EMSCfg_pu.ActivePwrCfg.PSpMin := Cfg_GVL.EMSCfg_eng.ActivePwrCfg.PSpMin / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t\t//Convert from MW to pu\nCfg_GVL.EMSCfg_pu.ActivePwrCfg.PUpLim := Cfg_GVL.EMSCfg_eng.ActivePwrCfg.PUpLim / Cfg_GVL.EMSCfg_eng.Snom / 60.0;\t\t\t\t\t\t//Convert from MW/min to pu/s\nCfg_GVL.EMSCfg_pu.ActivePwrCfg.PDnLim := Cfg_GVL.EMSCfg_eng.ActivePwrCfg.PDnLim / Cfg_GVL.EMSCfg_eng.Snom / 60.0;\t\t\t\t\t\t//Convert from MW/min to pu/s\nCfg_GVL.EMSCfg_pu.ActivePwrCfg.OvershootDbd1 := Cfg_GVL.EMSCfg_eng.ActivePwrCfg.OvershootDbd1 / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t//Convert from MW to pu\nCfg_GVL.EMSCfg_pu.ActivePwrCfg.OvershootDbd1 := Cfg_GVL.EMSCfg_eng.ActivePwrCfg.OvershootDbd1 / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t//Convert from MW to pu\n\n//Plant Level Reactive Power Config\nCfg_GVL.EMSCfg_pu.ReactivePwrCfg.QSpMax := Cfg_GVL.EMSCfg_eng.ReactivePwrCfg.QSpMax / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t//Convert from MVAr to pu\nCfg_GVL.EMSCfg_pu.ReactivePwrCfg.QSpMin := Cfg_GVL.EMSCfg_eng.ReactivePwrCfg.QSpMin / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t//Convert from MVAr to pu\nCfg_GVL.EMSCfg_pu.ReactivePwrCfg.QUpLim := Cfg_GVL.EMSCfg_eng.ReactivePwrCfg.QUpLim / Cfg_GVL.EMSCfg_eng.Snom / 60.0;\t\t\t\t\t//Convert from MVAr/min to pu/s\nCfg_GVL.EMSCfg_pu.ReactivePwrCfg.QDnLim := Cfg_GVL.EMSCfg_eng.ReactivePwrCfg.QDnLim / Cfg_GVL.EMSCfg_eng.Snom / 60.0;\t\t\t\t\t//Convert from MVAr/min to pu/s\n\n//Plant Level SOC Balancing Config\nCfg_GVL.EMSCfg_pu.SoCBalCfg.SoCDb := Cfg_GVL.EMSCfg_eng.SoCBalCfg.SoCDb / 100.0;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Convert from % to pu\nCfg_GVL.EMSCfg_pu.SoCBalCfg.PlantTol := Cfg_GVL.EMSCfg_eng.SoCBalCfg.PlantTol / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t\t//Convert from MW to pu\n\n//Alarms Cfg -> Scale alarm limit values from Eng. Units to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.PFbk.LoLo := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.PFbk.LoLo / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t//Convert from MW to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.PFbk.Lo := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.PFbk.Lo / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t//Convert from MW to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.PFbk.Hi := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.PFbk.Hi / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t//Convert from MW to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.PFbk.HiHi := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.PFbk.HiHi / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t//Convert from MW to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.QFbk.LoLo := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.QFbk.LoLo / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t//Convert from MVAr to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.QFbk.Lo := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.QFbk.Lo / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t//Convert from MVAr to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.QFbk.Hi := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.QFbk.Hi / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t\t//Convert from MVAr to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.QFbk.HiHi := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.QFbk.HiHi / Cfg_GVL.EMSCfg_eng.Snom;\t\t\t\t\t\t//Convert from MVAr to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.SOC.LoLo := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.SOC.LoLo / 100.0;\t\t\t\t\t\t\t\t\t\t\t//Convert from % to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.SOC.Lo := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.SOC.Lo / 100.0;\t\t\t\t\t\t\t\t\t\t\t\t//Convert from % to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.SOC.Hi := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.SOC.Hi / 100.0;\t\t\t\t\t\t\t\t\t\t\t\t//Convert from % to pu\nCfg_GVL.EMSCfg_pu.PlantAlarmCfg.SOC.HiHi := Cfg_GVL.EMSCfg_eng.PlantAlarmCfg.SOC.HiHi /100.0;\t\t\t\t\t\t\t\t\t\t\t//Convert from % to pu\n","LineInfoPersistence":"(string)a3f12778-fa3b-4e07-ab0f-fa6f4505b885_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_UpdatePlantCfgFromSCADA\nVAR_INPUT\nEND_VAR\n","LineInfoPersistence":"(string)a3f12778-fa3b-4e07-ab0f-fa6f4505b885_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}