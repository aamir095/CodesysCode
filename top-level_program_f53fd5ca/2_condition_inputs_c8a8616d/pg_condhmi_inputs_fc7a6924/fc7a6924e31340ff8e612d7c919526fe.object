{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)fc7a6924-e313-40ff-8e61-2d7c919526fe","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_CondHMI_Inputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)c8a8616d-fcb2-4b5a-a5f6-bef56d2e988e"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)HMI_Inputs_Scaled := HMI_Inputs;\n//Initialize Ramprate\nHMI_Inputs_Scaled.ActivePwrHMIInputs.Psp := HMI_Inputs.ActivePwrHMIInputs.Psp / EMSPlantCfg.Pnom; //scaled factor need to be added MW sp\nHMI_Inputs_Scaled.ReactivePwrHMIInputs.Qsp := HMI_Inputs.ReactivePwrHMIInputs.Qsp / EMSPlantCfg.Qnom; //scaled factor need to be added MWAR sp\n\n//HMI_Inputs_Scaled.PRampUpRt := HMI_Inputs.PRampUpRt / (EMSPlantCfg.Pnom *60); \t//Convert from MW/min to pu/s\n//HMI_Inputs_Scaled.PRampDnRt := HMI_Inputs.PRampDnRt / (EMSPlantCfg.Pnom *60);  \t//Convert from MW/min to pu/s\n//HMI_Inputs_Scaled.QRampUpRt := HMI_Inputs.QRampUpRt / (EMSPlantCfg.Qnom*60);\t//Convert from MVAR/min to pu/s\n//HMI_Inputs_Scaled.QRampDnRt := HMI_Inputs.QRampDnRt / (EMSPlantCfg.Qnom*60);\t//Convert from MVAR/min to pu/s\n\nFOR i:= 0 TO SiteConstants.NumLineups DO\n\tIF i > 0 THEN\n\t\tLineUp_Inputs_Scaled[i] \t\t\t:= LineUp_Inputs[i];\n\t\tLineUp_Inputs_Scaled[i].Psp \t\t:= LineUp_Inputs[i].Psp/ LineUpCfg[i].SNom; //scaled factor need to be added MW sp\n\t\tLineUp_Inputs_Scaled[i].Qsp \t\t:= LineUp_Inputs[i].Qsp/ LineUpCfg[i].SNom; //scaled factor need to be added MW sp\n\t\t//LineUp_Inputs_Scaled[i].PRampUpRt \t:= LineUp_Inputs[i].PRampUpRt/ (LineUpCfg[i].InvPnom * 60); //Convert from MW/min to pu/s\n\t\t//LineUp_Inputs_Scaled[i].PRampDnRt   := LineUp_Inputs[i].PRampDnRt/ (LineUpCfg[i].InvPnom * 60); //Convert from MW/min to pu/s\n\t\t//LineUp_Inputs_Scaled[i].QRampUpRt \t:= LineUp_Inputs[i].PRampUpRt/ (LineUpCfg[i].InvQnom * 60); //Convert from MVAR/min to pu/s\n\t\t//LineUp_Inputs_Scaled[i].QRampDnRt   := LineUp_Inputs[i].PRampDnRt/ (LineUpCfg[i].InvQnom * 60); //Convert from MVAR/min to pu/s\n\t\t//Added unit command if necessary\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)fc7a6924-e313-40ff-8e61-2d7c919526fe_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tTerabase Energy - Energy Managment System Battery Condition Inputs Program for HMI Inputs\n*)\nPROGRAM pg_CondHMI_Inputs\nVAR_INPUT\n\tHMI_Inputs \t\t: dt_HMIInputs;\t\t\t\t\t\t\t\t// HMI Inputs Raw\n\tLineUp_Inputs\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUHMIInputs; \t// Input Array of LineUp Commands\n\tLineUpCfg\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUCfg; \t\t//Input Array of LineUp Configuration\n\tEMSPlantCfg\t\t: dt_EMSCfg; \t\t\t\t\t\t\t\t\t\t\t//Input of EMS Plant Configuration\nEND_VAR\nVAR_OUTPUT\n\tHMI_Inputs_Scaled \t\t: dt_HMIInputs;\t\t\t\t\t\t\t\t\t\t// HMI Output Scaled\n\tLineUp_Inputs_Scaled\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUHMIInputs; \t// Output Array of LineUp Commands\nEND_VAR\nVAR\n\ti : UINT;\t// Unit Index\nEND_VAR\n","LineInfoPersistence":"(string)fc7a6924-e313-40ff-8e61-2d7c919526fe_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)82","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}