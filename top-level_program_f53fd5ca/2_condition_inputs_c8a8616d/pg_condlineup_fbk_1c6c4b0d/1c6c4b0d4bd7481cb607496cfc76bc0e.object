{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)1c6c4b0d-4bd7-481c-b607-496cfc76bc0e","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_CondLineUp_fbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)c8a8616d-fcb2-4b5a-a5f6-bef56d2e988e"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FOR i:= 0 TO SiteConstants.NumUnits DO\n\t// Moving the line up feedback to output\n\tLineUpFbk_Scaled[i] := LineUpFbk[i];\n\t//LineUpFbk_Scaled[i].AlmComm := TRUE;\n\t// Apllying Scale Factors\n\tLineUpFbk_Scaled[i].AvgSoC \t\t:= LineUpFbk[i].AvgSoC * LineUpCfg[i].SoC_SF;\n\tLineUpFbk_Scaled[i].AvgSoH \t\t:= LineUpFbk[i].AvgSoH * LineUpCfg[i].SoH_SF;\n\tLineUpFbk_Scaled[i].ContHumid \t:= LineUpFbk[i].ContHumid * LineUpCfg[i].Humid_SF;\n\tLineUpFbk_Scaled[i].ContTemp \t:= LineUpFbk[i].ContTemp * LineUpCfg[i].Temp_SF;\n\tLineUpFbk_Scaled[i].InvACPwr \t:= LineUpFbk[i].InvACPwr * LineUpCfg[i].InvACPwr_SF;\n\tLineUpFbk_Scaled[i].InvRePwr \t:= LineUpFbk[i].InvRePwr * LineUpCfg[i].InvRePwr_SF;\n\tLineUpFbk_Scaled[i].InvApPwr \t:= LineUpFbk[i].InvApPwr * LineUpCfg[i].InvApPwr_SF;\n\tLineUpFbk_Scaled[i].InvDCV \t\t:= LineUpFbk[i].InvDCV * LineUpCfg[i].InvDCV_SF;\n\tLineUpFbk_Scaled[i].InvDCA \t\t:= LineUpFbk[i].InvDCA * LineUpCfg[i].InvDCA_SF;\n\tLineUpFbk_Scaled[i].InvDCPwr \t:= LineUpFbk[i].InvDCPwr * LineUpCfg[i].InvDCPwr_SF;\n\tLineUpFbk_Scaled[i].PwrDisChaCap:= LineUpFbk[i].PwrDisChaCap * LineUpCfg[i].PwrDisChaCap_SF;\n\tLineUpFbk_Scaled[i].PwrChaCap \t:= LineUpFbk[i].PwrChaCap * LineUpCfg[i].PwrChaCap_SF;\n\tLineUpFbk_Scaled[i].RePwrAbsCap := LineUpFbk[i].RePwrAbsCap * LineUpCfg[i].RePwrAbsCap_SF;\n\tLineUpFbk_Scaled[i].RePwrInjCap := LineUpFbk[i].RePwrInjCap * LineUpCfg[i].RePwrInjCap_SF;\n\t\n\t(*\n\t//Providing LineUp Alarm\n\tIF LineupFbk_scaled[i].AlmComm THEN\n\t\tLineUpAlm[i].Alm_Comm := TRUE;\n\tEND_IF\n\tIF LineupFbk_scaled[i].AlmFire THEN\n\t\tLineUpAlm[i].Alm_Fire := TRUE;\n\tEND_IF\n\tIF LineupFbk_scaled[i].AlmHVAC THEN\n\t\tLineUpAlm[i].Alm_HVAC := TRUE;\n\tELSE\n\t\tLineUpAlm[i].Alm_HVAC := FALSE;\n\tEND_IF\n\tIF LineupFbk_scaled[i].StsFireSupp = TBE_EMS_DTs.enum_FireSupp_Sts.FAULT OR LineupFbk_scaled[i].StsHVAC = TBE_EMS_DTs.enum_HVAC_Sts.FAULT THEN\n\t\tLineUpAlm[i].Alm_Sys_Fault := TRUE;\n\tEND_IF\n\tIF LineupFbk_scaled[i].AvgSoC > LineUpCfg[i].HiSoC OR LineupFbk_scaled[i].AvgSoC < LineUpCfg[i].LoSoC THEN\n\t\tLineUpAlm[i].Alm_SoC := TRUE;\n\tELSE\n\t\tLineUpAlm[i].Alm_SoC := FALSE;\n\tEND_IF\n\tIF  LineupFbk_scaled[i].AvgSoH < LineUpCfg[i].LoSoH THEN\n\t\tLineUpAlm[i].Alm_SoH := TRUE;\n\tELSE\n\t\tLineUpAlm[i].Alm_SoC := FALSE;\n\tEND_IF\n\t*)\n\t\n\t\n\t(*\n\t// Calculate the EMS feedback based on Line Up Feedbacks\n\t\n\tIF LineUpFbk_Scaled[i].OpSts = TBE_EMS_DTs.enum_LineUp_Op.RUNNING THEN\n            Plant_NumLU_Avail  := Plant_NumLU_Avail + 1;\n            Plant_SoC_Total := Plant_SoC_Total + LineUpFbk_Scaled[i].AvgSoC;\n    END_IF\n\t// Plant Line Up availability % (count-based across Line Ups)\n\tIF SiteConstants.NumUnits > 0 THEN\n\t\tEMSFbk.LUAvailPct := (Plant_NumLU_Avail * 100.0) / (SiteConstants.NumUnits);\n\tELSE\n\t\tEMSFbk.LUAvailPct := 0.0;\n\tEND_IF\n\t\n\t// Plant SoC average across units with PCS available\n\tIF Plant_NumLU_Avail > 0 THEN\n\t\tEMSFbk.AvgSoC := Plant_SoC_Total / (Plant_NumLU_Avail);\n\tELSE\n\t\tEMSFbk.AvgSoC := 0.0;\n\tEND_IF\n\t*)\nEND_FOR","LineInfoPersistence":"(string)1c6c4b0d-4bd7-481c-b607-496cfc76bc0e_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tTerabase Energy - Energy Managment System Battery Condition Inputs Program for LineUp Feedbacks\n*)\nPROGRAM pg_CondLineUp_fbk\nVAR_INPUT\n\tLineUpFbk \t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUFbk; \t\t//Input Array of Unit Feedbacks raw\n\tLineUpCfg\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUCfg; //Input Array of Unit Configuration\nEND_VAR\nVAR_OUTPUT\n\tLineUpFbk_scaled\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUFbk;\t\t\t\t\t//Output Array of Unit Feedbacks scaled\n\t//LineUpAlm\t\t: ARRAY[0..SiteConstants.NumUnits] OF TBE_EMS_DTs.dt_LineUp_Alm;\t//Output Array of Unit Feedbacks scaled\n\t//EMSFbk\t\t\t: TBE_EMS_DTs.dt_EMS_Fbk;\nEND_VAR\nVAR\n\ti : UINT;\t// Unit Index\nEND_VAR\n","LineInfoPersistence":"(string)1c6c4b0d-4bd7-481c-b607-496cfc76bc0e_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)174","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}