{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)d40d47bd-7094-4b87-a750-844429f9bbfc","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_CondUnit_SCADA","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)9920103a-8fb5-4d6c-946f-c31651f5a42d"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FOR i:= 0 TO SiteConstants.NumUnits DO\n\tIF i > 0 THEN\n\t\t//LineUp Output Commands Scaled for SCADA\n\t\tLineUpCmd_SCADA[i] \t\t:= LineUpCmd_core[i];\n\t\tLineUpCmd_SCADA[i].Psp \t:= (LineUpCmd_core[i].Psp * LUCfg[i].SNom);\n\t\tLineUpCmd_SCADA[i].Qsp \t:= (LineUpCmd_core[i].Qsp * LUCfg[i].QNom);\n\t\t\n\t\t//LineUp Output Feedbacks Scaled for SCADA\n\t\tLineUpfbk_SCADA[i] := LineUpFbk_core[i];\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)d40d47bd-7094-4b87-a750-844429f9bbfc_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tTerabase Energy - Energy Managment System Battery Condition Outputs Program for SCADA/HMI\n*)\nPROGRAM pg_CondUnit_SCADA\nVAR_INPUT\n\tLineUpCmd_core \t: ARRAY[0..SiteConstants.NumUnits] OF dt_LUCmds;\t\t\t\t\t\t//Input Array of Unit Commands Scaled\n\tLineUpFbk_core \t: ARRAY[0..SiteConstants.NumUnits] OF dt_LUFbk;\t\t//Input Array of Unit Feedbacks Scaled\n\tLUCfg\t\t\t: ARRAY[0..SiteConstants.NumLineups] OF dt_LUCfg;\t\t\t\t\t\t//LU Configuration Structs\nEND_VAR\nVAR_OUTPUT\n\tLineUpCmd_SCADA \t: ARRAY[0..SiteConstants.NumUnits] OF dt_LUCmds;\t\t//Output Array of Unit Commands to SCADA\n\tLineUpFbk_SCADA \t: ARRAY[0..SiteConstants.NumUnits] OF dt_LUFbk;\t\t//Output Array of Unit Feedbacks to SCADA\nEND_VAR\nVAR\n\ti\t: UINT;\t\t\t//Unit Index\nEND_VAR\n","LineInfoPersistence":"(string)d40d47bd-7094-4b87-a750-844429f9bbfc_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)128","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}